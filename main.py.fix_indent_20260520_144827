    def download_updates_for_base(self, worker, base: BaseItem, idx: int, settings: Settings):
        run_base = self.prepare_base(base)
        program = guess_update_program_name(run_base)
        version = run_base.config_version.strip()
        platform_version = api_platform_version(run_base)

        worker.log('')
        worker.log(f'--- Скачивание обновлений для базы: {run_base.name} ---')
        worker.log(f'Текущая версия конфигурации: {version or "<не заполнена>"}')
        worker.log(f'Код программы обновлений: {program or "<не заполнен>"}')
        worker.log(f'Версия платформы для update-api: {platform_version}')

        if not version:
            worker.log(
                f'Версия конфигурации для базы {run_base.name} не заполнена. '
                f'Запускаю предварительную проверку настроек базы...'
            )

            try:
                self.check_one_base(worker, run_base, idx)

                run_base = self.app_config.bases[idx]

                version = (run_base.config_version or '' ).strip()
                program = (run_base.update_program_name or '' ).strip()
                platform_version = api_platform_version(run_base)

                worker.log(
                    f'После проверки определено: '
                    f'версия={version or "<не определена>"}, '
                    f'код={program or "<не определен>"}'
                )

            except Exception as e:
                worker.log(f'Ошибка предварительной проверки базы: {e}')

            if not version:
                worker.log(
                    'ПРОПУСК: не определена версия конфигурации даже после автоматической проверки.'
                )
                return
        if not program:
            worker.log('ПРОПУСК: не определён код программы обновлений 1С. Заполни поле «Код программы обновлений 1С» в свойствах базы. Для Бухгалтерии обычно: Accounting.')
            return

        api = OneCUpdateApi(settings.its_login, settings.its_password)
        worker.log(f'Проверка обновлений через update-api: programName={program}, versionNumber={version}, updateType={api.UPDATE_TYPE_WORKING}')
        info = api.check_conf_update(program, version, platform_version, allow_next_redaction=False)

        if not info:
            worker.log('Сервис не вернул доступных обновлений. Возможно, версия актуальна или неверный код программы.')
            return

        target = info.get('configurationVersion') or ''
        seq = info.get('upgradeSequence') or []
        program_uin = info.get('programVersionUin')
        worker.log(f'Целевая версия: {target}')
        worker.log(f'Минимальная/требуемая платформа по ответу API: {info.get("platformVersion") or "<не указана>"}')
        worker.log(f'Размер по ответу API: {info.get("size") or 0} байт')
        worker.log(f'Последовательность обновлений: {seq}')
        if info.get('updateInfoUrl'):
            worker.log(f'Информация о релизе: {info.get("updateInfoUrl")}')
        if info.get('howToUpdateInfoUrl'):
            worker.log(f'Как обновлять: {info.get("howToUpdateInfoUrl")}')

        if not seq or not program_uin:
            worker.log('ПРОПУСК: в ответе нет upgradeSequence/programVersionUin.')
            return

        data_list = api.get_conf_download_data(seq, program_uin)
        if not data_list:
            worker.log('ПРОПУСК: не получены данные для скачивания.')
            return

        # Новый layout: <updates_dir>/<Program>/<release_folder>/1cv8.cfu
        # Без длинного слоя 3.0.x_to_3.0.y/1c/Accounting.
        program_dir = update_program_dir(settings, program)
        raw_dir = program_dir / '_archives'
        meta_dir = program_dir / '_metadata'
        program_dir.mkdir(parents=True, exist_ok=True)
        raw_dir.mkdir(parents=True, exist_ok=True)
        meta_dir.mkdir(parents=True, exist_ok=True)
        update_info = {
            'request': {'program': program, 'version': version, 'platformVersion': platform_version, 'updateType': api.UPDATE_TYPE_WORKING},
            'info': info,
            'files': data_list,
        }
        meta_name = f'update_info_{safe_name(version)}_to_{safe_name(target or "unknown")}_{now_stamp()}.json'
        (meta_dir / meta_name).write_text(json.dumps(update_info, ensure_ascii=False, indent=2), encoding='utf-8')
        (program_dir / 'latest_update_info.json').write_text(json.dumps(update_info, ensure_ascii=False, indent=2), encoding='utf-8')

        for n, item in enumerate(data_list, 1):
            url = item.get('updateFileUrl')
            fname = item.get('updateFileName') or Path(url or '').name or f'update_{n}.zip'
            if not url:
                worker.log(f'Пропуск элемента без URL: {item}')
                continue

            template_path = item.get('templatePath') or ''
            fallback_release = seq[n-1] if n-1 < len(seq) else Path(fname).stem
            release_dir_name = update_release_folder(template_path, version_to_update_folder(str(fallback_release)))
            extract_dir = program_dir / release_dir_name

            raw_name = f'{release_dir_name}_{safe_name(fname)}'
            if not raw_name.lower().endswith('.zip') and (item.get('updateFileFormat') or '').lower() == 'zip':
                raw_name += '.zip'
            dest = raw_dir / raw_name

            worker.log('')
            worker.log(f'Скачивание {n}/{len(data_list)}: {url}')
            worker.log(f'Имя файла: {fname}')
            worker.log(f'Папка шаблона из API: {template_path}')
            worker.log(f'Папка релиза: {extract_dir}')
            api.download_file(url, dest, worker)

            ok, hash_text = verify_hash_if_possible(dest, item.get('hashSum') or '')
            if hash_text:
                worker.log(f'Проверка hashSum: {hash_text}; результат: {"OK" if ok else "НЕ СОВПАЛ"}')
            if not ok:
                raise RuntimeError(f'HashSum не совпал для {dest}')

            if zipfile.is_zipfile(dest):
                # Распаковываем во временную папку, затем переносим релизы в плоский layout:
                # <updates_dir>/<Program>/<release>/...
                temp_extract_dir = program_dir / f'_extract_{release_dir_name}_{now_stamp()}'
                if temp_extract_dir.exists():
                    shutil.rmtree(temp_extract_dir)
                unzip_1c_zip(dest, temp_extract_dir)
                worker.log(f'Распаковано во временную папку: {temp_extract_dir}')
                normalized_dirs = normalize_extracted_update_tree(worker, program_dir, temp_extract_dir, str(fallback_release))
                if not normalized_dirs:
                    # Если нормализация ничего не нашла, оставим как было в папке релиза для диагностики.
                    if extract_dir.exists():
                        shutil.rmtree(extract_dir)
                    if temp_extract_dir.exists():
                        temp_extract_dir.rename(extract_dir)
                    worker.log(f'Не удалось нормализовать структуру. Оставлено для диагностики: {extract_dir}')
                try:
                    dest.unlink()
                    worker.log(f'Архив после распаковки удален: {dest}')
                except Exception as e:
                    worker.log(f'Не удалось удалить архив {dest}: {e}')
            else:
                worker.log('Файл не похож на zip, оставлен как скачанный архив.')

        # Удалим пустую папку архивов, если все архивы удалились.
        try:
            if raw_dir.exists() and not any(raw_dir.iterdir()):
                raw_dir.rmdir()
        except Exception:
            pass

        cleanup_old_long_update_layout(worker, settings, program)

        worker.log('')
        worker.log(f'Готово. Папка обновлений программы: {program_dir}')

        if idx is not None and not self.app_config.bases[idx].update_program_name and is_valid_update_program_name(program):
            self.app_config.bases[idx].update_program_name = program
            self.app_config.save()
            worker.refresh_signal.emit()


