    def open_current_log_stub(self):
        self.open_reports_dir()

    def save_report_log(self):
        try:
            path = Path(self.app_config.settings.reports_dir).expanduser() / f'obnovlyator_report_{now_stamp()}.log'
            path.parent.mkdir(parents=True, exist_ok=True)
            path.write_text(self.report.toPlainText(), encoding='utf-8')
            QMessageBox.information(self, 'Лог сохранен', f'Лог сохранен:\n{path}')
        except Exception as e:
