def _clearcache_user_homes(all_users: bool) -> List[Path]:
    if not all_users:
        return [Path.home()]

    homes = []
    for p in sorted(Path('/home').iterdir()) if Path('/home').exists() else []:
        if p.is_dir():
            homes.append(p)
    if Path('/root').exists():
        homes.append(Path('/root'))

    current = Path.home()
    if current not in homes:
        homes.insert(0, current)

    result = []
    seen = set()
    for h in homes:
        key = str(h)
        if key not in seen:
            seen.add(key)
            result.append(h)
    return result


def _clearcache_local_roots(home: Path) -> List[Path]:
    # Аналог Windows LocalAppData\1C: локальный кэш, который можно чистить почти полностью.
    return [
        home / '.cache' / '1C',
        home / '.cache' / '1cv8',
        home / '.1cv8' / '1C',
    ]


def _clearcache_roaming_roots(home: Path) -> List[Path]:
    # Аналог Windows AppData\Roaming\1C: настройки профиля.
    # Здесь по умолчанию удаляем только cache*.
    return [
        home / '.1C',
        home / '.config' / '1C',
        home / '.local' / 'share' / '1C',
    ]


def _clearcache_is_license_path(path: Path) -> bool:
    parts = [p.lower() for p in path.parts]
    return path.name.lower().endswith('.lic') or 'licenses' in parts


def _clearcache_delete_target(path: Path, method: str, worker=None) -> bool:
    if 'только показать' in method:
        if worker:
            worker.log(f'[план] {path}')
        return True

    try:
        if 'корзин' in method:
            gio = shutil.which('gio')
            if gio:
                subprocess.run([gio, 'trash', str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, timeout=20)
                if not path.exists():
                    return True
                # Если gio не смог, дальше удалим штатно, чтобы операция не зависала.
                if worker:
                    worker.log(f'gio trash не удалил объект, удаляю напрямую: {path}')

        if path.is_dir() and not path.is_symlink():
            shutil.rmtree(path, ignore_errors=False)
        else:
            path.unlink(missing_ok=True)

        return not path.exists()

    except Exception as e:
        if worker:
            worker.log(f'Не удалось удалить {path}: {e}')
        return False


def _clearcache_remove_empty_dirs(root: Path, worker=None):
    if not root.exists() or not root.is_dir():
        return

    for dirpath, dirnames, filenames in os.walk(root, topdown=False):
        p = Path(dirpath)
        if p == root or _clearcache_is_license_path(p):
            continue
        try:
            p.rmdir()
        except Exception:
            pass


def _clearcache_clean_local_cache(worker, home: Path, method: str) -> Tuple[int, int]:
    deleted = errors = 0

    for root in _clearcache_local_roots(home):
        if not root.exists():
            continue

        worker.log(f'Локальный кэш: {root}')

        for dirpath, dirnames, filenames in os.walk(root, topdown=True):
            # Не заходим в licenses.
            dirnames[:] = [d for d in dirnames if d.lower() != 'licenses']
            current = Path(dirpath)

            for name in filenames:
                p = current / name
                if _clearcache_is_license_path(p):
                    continue
                if _clearcache_delete_target(p, method, worker):
                    deleted += 1
                else:
                    errors += 1

        if 'только показать' not in method:
            _clearcache_remove_empty_dirs(root, worker)

    return deleted, errors


def _clearcache_clean_cache_files(worker, home: Path, method: str) -> Tuple[int, int]:
    deleted = errors = 0

    for root in _clearcache_roaming_roots(home):
        if not root.exists():
            continue

        worker.log(f'Профиль 1С/cache*: {root}')

        for dirpath, dirnames, filenames in os.walk(root, topdown=False):
            current = Path(dirpath)

            for name in filenames:
                if name.lower().startswith('cache'):
                    p = current / name
                    if _clearcache_is_license_path(p):
                        continue
                    if _clearcache_delete_target(p, method, worker):
                        deleted += 1
                    else:
                        errors += 1

            for name in dirnames:
                if name.lower().startswith('cache'):
                    p = current / name
                    if _clearcache_is_license_path(p):
                        continue
                    if _clearcache_delete_target(p, method, worker):
                        deleted += 1
                    else:
                        errors += 1

    return deleted, errors


def _clearcache_clean_session_settings(worker, home: Path, method: str) -> Tuple[int, int]:
    deleted = errors = 0
    names_exact = {'def.usr'}
    suffixes = {'.pfl', '.usr'}

    for root in _clearcache_roaming_roots(home):
        if not root.exists():
            continue

        worker.log(f'Настройки между сеансами: {root}')

        for dirpath, dirnames, filenames in os.walk(root, topdown=False):
            current = Path(dirpath)
            for name in filenames:
                lower = name.lower()
                if lower in names_exact or any(lower.endswith(s) for s in suffixes):
                    p = current / name
                    if _clearcache_is_license_path(p):
                        continue
                    if _clearcache_delete_target(p, method, worker):
                        deleted += 1
                    else:
                        errors += 1

    return deleted, errors


def _clearcache_clean_keep_last(worker, root: Path, keep_count: int, method: str, title: str) -> Tuple[int, int]:
    deleted = errors = 0
    if not root.exists():
        return deleted, errors

    worker.log(f'{title}: {root}, оставить последних: {keep_count}')

    # Чистим по прямым дочерним папкам каждой программы/раздела.
    for parent in [root] + [p for p in root.iterdir() if p.is_dir()]:
        try:
            children = [p for p in parent.iterdir() if p.is_dir()]
        except Exception:
            continue

        if len(children) <= keep_count:
            continue

        children.sort(key=lambda p: p.stat().st_mtime, reverse=True)
        for p in children[keep_count:]:
            if _clearcache_delete_target(p, method, worker):
                deleted += 1
            else:
                errors += 1

    return deleted, errors


def _clearcache_clean_older_than(worker, root: Path, days: int, method: str, title: str) -> Tuple[int, int]:
    deleted = errors = 0
    if not root.exists():
        return deleted, errors

    threshold = time.time() - max(days, 0) * 86400
    worker.log(f'{title}: {root}, старше дней: {days}')

    for dirpath, dirnames, filenames in os.walk(root, topdown=False):
        current = Path(dirpath)

        for name in filenames:
            p = current / name
            try:
                if p.stat().st_mtime < threshold:
                    if _clearcache_delete_target(p, method, worker):
                        deleted += 1
                    else:
                        errors += 1
            except Exception as e:
                worker.log(f'Не удалось проверить {p}: {e}')
                errors += 1

        # Пустые старые папки.
        for name in dirnames:
            p = current / name
            try:
                if p.exists() and p.stat().st_mtime < threshold and not any(p.iterdir()):
                    if _clearcache_delete_target(p, method, worker):
                        deleted += 1
                    else:
                        errors += 1
            except Exception:
                pass

    return deleted, errors


def _clearcache_clean_tmp(worker, method: str) -> Tuple[int, int]:
    deleted = errors = 0
    patterns = [
        '/tmp/u1c*',
        '/tmp/1C*',
        '/tmp/1c*',
        '/tmp/v8_*',
        '/tmp/v8-*',
    ]

    worker.log('Временные файлы /tmp по маскам: ' + ', '.join(patterns))

    seen = set()
    for pattern in patterns:
        for p in Path('/tmp').glob(Path(pattern).name):
            key = str(p)
            if key in seen:
                continue
            seen.add(key)
            if _clearcache_is_license_path(p):
                continue
            if _clearcache_delete_target(p, method, worker):
                deleted += 1
            else:
                errors += 1

    return deleted, errors


def run_linux_1c_cache_cleanup(worker, settings: Settings, values: dict):
    method = values.get('method') or 'удалить в корзину'
    homes = _clearcache_user_homes(values.get('all_users', False))

    worker.log('Очистка кэша 1С для Linux/Ubuntu')
    worker.log(f'Метод очистки: {method}')
    worker.log('Пользователи/профили:')
    for h in homes:
        worker.log(f'  {h}')

    total_deleted = 0
    total_errors = 0

    for home in homes:
        worker.log('')
        worker.log(f'--- Профиль: {home} ---')

        if values.get('clean_temp'):
            d, e = _clearcache_clean_local_cache(worker, home, method)
            total_deleted += d
            total_errors += e

        if values.get('clean_cache_files'):
            d, e = _clearcache_clean_cache_files(worker, home, method)
            total_deleted += d
            total_errors += e

        if values.get('clean_session_settings'):
            d, e = _clearcache_clean_session_settings(worker, home, method)
            total_deleted += d
            total_errors += e

    if values.get('clean_update_templates'):
        d, e = _clearcache_clean_keep_last(
            worker,
            Path(settings.updates_dir).expanduser(),
            max(values.get('keep_templates', 1000), 0),
            method,
            'Папки обновлений'
        )
        total_deleted += d
        total_errors += e

    if values.get('clean_platform_dists'):
        d, e = _clearcache_clean_keep_last(
            worker,
            Path(settings.platform_download_dir).expanduser(),
            0,
            method,
            'Скачанные дистрибутивы платформы'
        )
        total_deleted += d
        total_errors += e

    if values.get('clean_reports'):
        d, e = _clearcache_clean_older_than(
            worker,
            Path(settings.reports_dir).expanduser(),
            values.get('report_days', 360),
            method,
            'Отчёты обновлятора'
        )
        total_deleted += d
        total_errors += e

    if values.get('clean_updater_temp'):
        d, e = _clearcache_clean_tmp(worker, method)
        total_deleted += d
        total_errors += e

    worker.log('')
    if 'только показать' in method:
        worker.log(f'План очистки сформирован. Объектов в плане: {total_deleted}, ошибок проверки: {total_errors}')
    else:
        worker.log(f'Очистка завершена. Удалено/перемещено объектов: {total_deleted}, ошибок: {total_errors}')



