    def delete_base(self):
        item = self.tree.currentItem()
        if not item:
            QMessageBox.information(self, 'Нет выбора', 'Выберите базу или группу.')
            return

        idx = item.data(0, Qt.UserRole)

        if not isinstance(idx, int):
            self.delete_selected_group()
            return

        base = self.app_config.bases[idx]
        if QMessageBox.question(
            self,
            'Удалить',
            f'Удалить базу «{base.name}» из списка?\n\nФайлы базы на диске не удаляются.',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        ) == QMessageBox.Yes:
            self.checked_base_keys.discard(self.base_key(base))
            del self.app_config.bases[idx]
            self.current_base_index = None
            self.app_config.save()
            self.refresh_tree()
            self.log(f'База «{base.name}» удалена из списка. Файлы базы на диске не удалялись.')

    def import_v8i(self):
        default = default_ibases_path(); path, _ = QFileDialog.getOpenFileName(self, 'Выберите ibases.v8i', str(default if default.exists() else Path.home()), '1C infobases (*.v8i);;All files (*)')
        if not path: return
        try: new_bases = parse_v8i(Path(path))
        except Exception as e: QMessageBox.critical(self,'Ошибка импорта',str(e)); return
        existing = {
            b.connect: i
            for i, b in enumerate(self.app_config.bases)
            if not is_group_placeholder_base(b)
        }
        added = updated = skipped = 0
        for b in new_bases:
            if is_group_placeholder_base(b):
                skipped += 1
                continue
            if b.connect in existing:
                old = self.app_config.bases[existing[b.connect]]
                b.user, b.password, b.db_type, b.db_host, b.db_port, b.db_name, b.db_user, b.db_password = old.user, old.password, old.db_type, old.db_host, old.db_port, old.db_name, old.db_user, old.db_password
                b.config_name, b.config_synonym, b.config_version, b.update_program_name = old.config_name, old.config_synonym, old.config_version, old.update_program_name
                b.client_mode = getattr(old, 'client_mode', getattr(b, 'client_mode', 'thin'))
                self.app_config.bases[existing[b.connect]] = b; updated += 1
            else:
                self.app_config.bases.append(b); added += 1
        self.app_config.save(); self.refresh_tree(); self.log(f'Импортировано из {path}: добавлено {added}, обновлено {updated}, пропущено групп/папок {skipped}.')
    def set_busy(self, busy: bool):
        for btn in self.operation_buttons:
            btn.setEnabled(not busy)
        if hasattr(self, 'btn_cancel_operation'):
            self.btn_cancel_operation.setEnabled(busy)

    def cancel_current_operation(self):
        if self.worker and self.worker.isRunning():
            self.worker.request_cancel()
            self.log('Отмена запрошена пользователем. Дождись завершения текущего этапа 1С.')
            self.btn_cancel_operation.setEnabled(False)
        else:
            self.log('Нет активной операции для отмены.')

    def start_worker(self, title: str, func):
        if self.worker and self.worker.isRunning():
            QMessageBox.information(self,'Операция выполняется','Дождитесь завершения текущей операции или нажмите «Отменить действие».')
            return
        self.worker = OperationWorker(title, func)
        self.worker.log_signal.connect(self.log)
        self.worker.done_signal.connect(self.worker_done)
        self.worker.refresh_signal.connect(self.refresh_tree)
        self.set_busy(True)
        self.worker.start()

    def worker_done(self, ok: bool, text: str):
        self.set_busy(False)
        self.refresh_tree()
        self.log(text)
        if 'отменено' in text.lower():
            title = 'Отменено'
        else:
            title = 'Готово' if ok else 'Ошибка'
        QMessageBox.information(self, title, text)

    def resolve_platform_exe(self, base: BaseItem) -> Optional[str]:
        version = (base.platform_version or '').strip()

        # Пусто/auto — глобальная настройка или самая свежая найденная 8.*.
        if is_auto_platform_version(version):
            return default_platform_exe_for_generic(self.app_config.settings.selected_platform)

        # 8.* / 8.3 / 8.5 / конкретная версия — для пакетных операций берем технический exe.
        if version == '8.*':
            return default_platform_exe_for_generic(self.app_config.settings.selected_platform)

        return find_platform_exe_for_version(version)


    def choose_platform_exe(self, base: BaseItem) -> Optional[str]:
        exe = self.resolve_platform_exe(base)
        if not exe:
            QMessageBox.warning(self, 'Платформа не найдена', f'Не найдена платформа 1С для версии: {base.platform_version or "8.3"}.\n\nНайденные платформы:\n{platform_versions_text()}\n\nПроверь установленную версию или выбери 8.3 для автоопределения.')
        return exe

    def prepare_base(self, base: BaseItem) -> BaseItem:
        b = dataclass_from_dict(BaseItem, asdict(base))
        normalize_base(b)
        return b
    def run_base(self, mode: str):
        base = self.selected_base()
        if not base:
            QMessageBox.information(self,'Нет базы','Выберите базу.')
            return

        run_base = self.prepare_base(base)

        if run_base.kind == 'web':
            if mode != 'ENTERPRISE':
                QMessageBox.warning(self,'Web-база','Конфигуратор для web-базы по URL не запускается.')
                return

            if self.app_config.settings.web_launch_mode == 'browser':
                webbrowser.open(run_base.connect)
                self.log(f'Открываю web-базу в браузере: {run_base.connect}')
                return

            exe = select_web_platform_exe(run_base, self.app_config.settings)
            self.log(f'Web-база. Выбранная версия платформы: {run_base.platform_version or "auto"}')
            self.log(f'Режим запуска: {run_base.client_mode or "thin"}')
            self.log('Найденные платформы: ' + platform_versions_text())

            if not exe:
                self.log('Не найден исполняемый файл 1С для выбранной версии. Открываю URL в браузере.')
                webbrowser.open(run_base.connect)
                return

            p = Path(exe)
            if not p.exists():
                self.log(f'Исполняемый файл не найден: {p}')
                webbrowser.open(run_base.connect)
                return

            if not os.access(p, os.X_OK):
                self.log(f'Файл найден, но не исполняемый: {p}')
                self.log(f'Исправить можно командой: chmod +x {p}')
                return

            self.log(f'Выбран исполняемый файл: {exe}')
            args = build_web_args_for_exe(run_base, exe)
            start_process_and_log_quick_exit(
                self.log,
                args,
                self.app_config.settings.reports_dir,
                run_base.name,
                wait_seconds=3,
                suffix='web_launch'
            )
            return

        # Диагностика файловой базы до запуска.
        if run_base.kind == 'file':
            base_dir = Path(run_base.connect)
            if not base_dir.exists():
                self.log(f'ОШИБКА: папка файловой базы не найдена: {base_dir}')
                QMessageBox.warning(self, 'Файловая база не найдена', f'Папка не найдена:\n{base_dir}')
                return
            if not (base_dir / '1Cv8.1CD').exists():
                self.log(f'ПРЕДУПРЕЖДЕНИЕ: в папке не найден файл 1Cv8.1CD: {base_dir}')

        if mode == 'ENTERPRISE':
            platform = select_interactive_platform_exe(run_base, self.app_config.settings)
            if not platform:
                QMessageBox.warning(self, 'Платформа не найдена', f'Не найдена платформа 1С для версии: {run_base.platform_version or "8.*"}.\n\nНайденные платформы:\n{platform_versions_text()}')
                return
        else:
            platform = self.choose_platform_exe(run_base)
            if not platform:
                return

        p = Path(platform)
        if not p.exists():
            self.log(f'ОШИБКА: исполняемый файл платформы не найден: {p}')
            QMessageBox.warning(self, 'Платформа не найдена', str(p))
            return
        if not os.access(p, os.X_OK):
            self.log(f'ОШИБКА: файл платформы не исполняемый: {p}')
            self.log(f'Исправить можно командой: chmod +x {p}')
            QMessageBox.warning(self, 'Нет прав запуска', f'Файл не исполняемый:\n{p}')
            return

        # Добавляем /Out только для интерактивного запуска из кнопок, чтобы увидеть причину быстрого завершения.
        # Для пакетных операций в других функциях логи формируются отдельно.
        launch_log = Path(self.app_config.settings.reports_dir) / f'{safe_name(run_base.name)}_{mode}_ui_{now_stamp()}.out'
        extra = ['/Out', str(launch_log), '-NoTruncate']
        args = build_1c_args(run_base, mode, platform, extra)

        self.log(f'Выбран исполняемый файл платформы: {platform}')
        self.log(f'Режим 1С: {mode}')
        self.log(f'Версия/семейство платформы в карточке: {run_base.platform_version}')
        self.log(f'Лог /Out 1С: {launch_log}')

        start_process_and_log_quick_exit(
            self.log,
            args,
            self.app_config.settings.reports_dir,
            run_base.name,
            wait_seconds=3,
            suffix=f'{mode.lower()}_launch'
        )

    def run_enterprise(self): self.run_base('ENTERPRISE')
    def run_designer(self): self.run_base('DESIGNER')
    def ensure_dirs(self):
        s = self.app_config.settings; Path(s.backup_dir).mkdir(parents=True, exist_ok=True); Path(s.reports_dir).mkdir(parents=True, exist_ok=True); Path(s.updates_dir).mkdir(parents=True, exist_ok=True)
    def get_pg_dump_path(self):
