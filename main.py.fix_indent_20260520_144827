def build_web_args_for_exe(base: BaseItem, exe: str) -> List[str]:
    args = [exe, 'ENTERPRISE', quote_param('/WS', base.connect)]
    if base.user:
        args.append(quote_param('/N', base.user))
    if base.password:
        args.append(quote_param('/P', base.password))
    if base.launch_parameters:
        args.extend(shlex.split(base.launch_parameters))
    return args


def start_process_and_log_quick_exit(
    log_func,
    args: List[str],
    reports_dir: str,
    base_name: str,
    wait_seconds: int = 3,
    suffix: str = 'launch',
):
    """Один запуск с проверкой быстрого завершения.

    Используется для web, предприятия и конфигуратора.
    Если процесс быстро завершился — выводим код и хвост stdout/stderr.
    Если процесс живой — пишем PID и больше не мешаем.
    """
    Path(reports_dir).mkdir(parents=True, exist_ok=True)
    log_file = Path(reports_dir) / f'{safe_name(base_name)}_{suffix}_{now_stamp()}.log'

    log_func('Запуск: ' + command_to_text(args))
    log_func(f'Лог запуска: {log_file}')

    try:
        launch_env = build_1c_env_for_args(args)
        env_text = env_short_text(launch_env)
        if env_text:
            log_func('Окружение запуска: ' + env_text)

        with open(log_file, 'w', encoding='utf-8', errors='replace') as f:
            p = subprocess.Popen(args, stdout=f, stderr=subprocess.STDOUT, env=launch_env)

        time.sleep(wait_seconds)
        rc = p.poll()

        if rc is None:
            log_func(f'Процесс запущен и не завершился за {wait_seconds} сек. PID={p.pid}')
            return True

        log_func(f'Процесс быстро завершился. Код завершения: {rc}')
        tail = tail_file(log_file, 120)
        if tail:
            log_func('Хвост лога запуска:')
            log_func(tail)
        else:
            log_func('Лог запуска пустой. Возможная причина: 1С завершилась без вывода в stdout/stderr.')
        return False

    except Exception as e:
        log_func(f'Не удалось запустить команду: {e}')
        return False




