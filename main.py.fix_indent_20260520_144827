        self.check_refs = QCheckBox('Проверка ссылочной целостности информационной базы')
        self.check_refs.setChecked(True)

        self.bad_ref_action = QComboBox()
        self.bad_ref_action.addItems(['не изменять', 'создавать объекты', 'очищать ссылки'])
        self.bad_data_action = QComboBox()
