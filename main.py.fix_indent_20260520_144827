    def build_rac_lock_template(self, base: BaseItem, vals: dict):
        rac = self.app_config.settings.rac_path or 'rac'
        ras = f"{self.app_config.settings.ras_address}:{self.app_config.settings.ras_port}"
        cmds = [
            [rac, ras, 'cluster', 'list'],
            [rac, ras, 'infobase', 'summary', 'list', '--cluster=<cluster-guid>'],
        ]
        update_cmd = [rac, ras, 'infobase', 'update', '--cluster=<cluster-guid>', '--infobase=<infobase-guid>']
        if vals.get('deny_sessions'):
            update_cmd.append('--sessions-deny=on')
        if vals.get('deny_jobs'):
            update_cmd.append('--scheduled-jobs-deny=on')
        update_cmd.extend(['--permission-code=' + vals.get('code', 'updater1c')])
        if vals.get('message'):
            update_cmd.extend(['--denied-message=' + vals.get('message')])
        cmds.append(update_cmd)
        if vals.get('terminate_sessions'):
            cmds.append([rac, ras, 'session', 'terminate', '--cluster=<cluster-guid>', '--session=<session-guid>'])
        return cmds

