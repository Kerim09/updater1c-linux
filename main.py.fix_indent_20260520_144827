    def make_file_1cd_backup(self, worker, base: BaseItem) -> Path:
        self.ensure_dirs()
        if base.kind != 'file':
            raise RuntimeError('Архив 1Cv8.1CD доступен только для файловой базы')
        src_dir = Path(base.connect)
        src = src_dir / '1Cv8.1CD'
        if not src.exists():
            # На Linux регистр важен, иногда файл может быть 1cv8.1cd.
            matches = list(src_dir.glob('*.1CD')) + list(src_dir.glob('*.1cd'))
            src = matches[0] if matches else src
        if not src.exists():
            raise RuntimeError(f'Файл базы 1Cv8.1CD не найден в {src_dir}')
        dest_dir = Path(self.app_config.settings.backup_dir) / safe_name(base.name)
        dest_dir.mkdir(parents=True, exist_ok=True)
        dest = dest_dir / f'{safe_name(base.name)}_{now_stamp()}_1Cv8.1CD.tar.gz'
        worker.log(f'Создается архив файла 1Cv8.1CD: {dest}')
        with tarfile.open(dest, 'w:gz') as tar:
            tar.add(src, arcname='1Cv8.1CD')
        worker.log(f'Архив 1Cv8.1CD создан: {dest}')
        return dest

    def restore_file_1cd_backup(self, worker, base: BaseItem, backup_file: Path):
        if base.kind != 'file':
            raise RuntimeError('Откат 1Cv8.1CD доступен только для файловой базы')
        target = Path(base.connect) / '1Cv8.1CD'
        worker.log(f'Откат файловой базы из архива: {backup_file}')
        with tarfile.open(backup_file, 'r:gz') as tar:
            member = tar.getmember('1Cv8.1CD')
            src = tar.extractfile(member)
            if src is None:
                raise RuntimeError('В архиве не найден 1Cv8.1CD')
            tmp = target.with_suffix('.1CD.restore_tmp')
            with tmp.open('wb') as f:
                shutil.copyfileobj(src, f)
            tmp.replace(target)
        worker.log('Файловая база восстановлена из архива 1Cv8.1CD.')

    def make_mssql_backup(self, worker, base: BaseItem) -> Path:
        self.ensure_dirs()
        if not base.db_name:
            raise RuntimeError('В свойствах базы не указано имя MSSQL database')
        dest_dir = Path(self.app_config.settings.backup_dir) / safe_name(base.name)
        dest_dir.mkdir(parents=True, exist_ok=True)
        dest = dest_dir / f'{safe_name(base.name)}_{now_stamp()}.bak'
        sqlcmd = shutil.which('sqlcmd')
        if not sqlcmd:
            raise RuntimeError('sqlcmd не найден. Установи Microsoft sqlcmd-tools или выбери .dt backup.')
        query = f"BACKUP DATABASE [{base.db_name}] TO DISK=N'{dest}' WITH INIT, COMPRESSION, STATS=10"
        args = [sqlcmd, '-S', base.db_host or 'localhost', '-U', base.db_user or 'sa', '-P', base.db_password, '-Q', query]
        run_command(worker, args)
        worker.log(f'MSSQL .bak backup создан: {dest}')
        return dest

    def make_native_backup(self, worker, base: BaseItem) -> Path:
        self.ensure_dirs()
        dest_dir = Path(self.app_config.settings.backup_dir) / safe_name(base.name)
        dest_dir.mkdir(parents=True, exist_ok=True)
        if base.kind == 'file':
            return self.make_file_1cd_backup(worker, base)
        if base.kind == 'server':
            dbt = (base.db_type or 'postgresql').lower()
            if dbt == 'mssql':
                return self.make_mssql_backup(worker, base)
            pg = self.get_pg_dump_path()
            if not pg:
                raise RuntimeError('pg_dump не найден')
            if not base.db_name:
                raise RuntimeError('В свойствах базы не указано имя PostgreSQL database')
            dest = dest_dir / f'{safe_name(base.name)}_{now_stamp()}.dump'
            args = [pg,'-h',base.db_host or 'localhost','-p',base.db_port or '5432','-U',base.db_user or 'postgres','-F','c','-f',str(dest),base.db_name]
            env = {'PGPASSWORD': base.db_password} if base.db_password else {}
            run_command(worker, args, env)
            worker.log(f'pg_dump backup создан: {dest}')
            return dest
        raise RuntimeError('Для web-базы backup не реализован')

