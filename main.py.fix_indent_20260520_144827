        buttons.addWidget(ok)
        buttons.addWidget(cancel)

        layout = QVBoxLayout(self)
        layout.addLayout(form)
        note = QLabel('Опасная операция. По умолчанию команда только показывается в отчете. Для выполнения поставь галочку “Выполнить команду”.')
        note.setWordWrap(True)
        layout.addWidget(note)
        layout.addStretch()
        layout.addLayout(buttons)

    def get_values(self):
        args = ['/IBCheckAndRepair']
        if not self.repair.isChecked():
            args.append('-TestOnly')
        if self.check_extensions.isChecked():
            args.append('-LogIntegrityExtensions')
        if self.check_logical.isChecked():
            args.append('-LogIntegrity')
        if self.check_refs.isChecked():
            args.append('-LogAndRefsIntegrity')

        ref = self.bad_ref_action.currentText()
        if ref == 'создавать объекты':
            args.append('-BadRefCreate')
        elif ref == 'очищать ссылки':
            args.append('-BadRefClear')
        else:
            args.append('-BadRefNone')

        data = self.bad_data_action.currentText()
        if data == 'создавать объекты':
            args.append('-BadDataCreate')
        elif data == 'очищать объекты':
            args.append('-BadDataDelete')

        if self.reindex.isChecked():
            args.append('-ReIndex')
        if self.compress.isChecked():
            args.append('-IBCompression')
        if self.recalc_totals.isChecked():
            args.append('-RecalcTotals')
        if self.rebuild.isChecked():
            args.append('-Rebuild')
        if self.resume.isChecked():
            args.append('-UseStartPoint')

        limit = self.time_limit.text().strip()
        if limit:
            try:
                minutes = int(limit)
                hours = minutes // 60
                mins = minutes % 60
                args.append(f'-TimeLimit:{hours:03d}:{mins:02d}')
            except Exception:
                pass

        return {'args': args, 'execute': self.execute.isChecked()}


