    def save_detected_metadata(self, idx, name: str, syn: str, ver: str, worker) -> bool:
        name, syn, ver = normalize_detected_metadata(name, syn, ver)
        if not (name or syn or ver):
            return False
        worker.log(f'Определено: name={name}, synonym={syn}, version={ver}')
        if idx is not None:
            b = self.app_config.bases[idx]
            b.config_name = name or b.config_name
            b.config_synonym = syn or b.config_synonym
            b.config_version = ver or b.config_version
            b.update_program_name = sanitize_update_program_name(b.update_program_name)
            guessed_program = guess_update_program_name(b)
            if not b.update_program_name and guessed_program:
                b.update_program_name = guessed_program
            self.app_config.save(); worker.refresh_signal.emit()
        return True

    def try_metadata_execute(self, worker, run_base: BaseItem, platform: str, idx) -> bool:
        epf = (self.app_config.settings.metadata_probe_path or '').strip()

        if is_stale_metadata_probe_path(epf):
            bundled = bundled_metadata_probe_path()
            if bundled:
                epf = bundled
                self.app_config.settings.metadata_probe_path = bundled
                self.app_config.save()

        if not epf:
            worker.log('Метод /Execute пропущен: путь к внешней обработке не указан и встроенная DbInfo.epf не найдена.')
            return False

        if not Path(epf).exists():
            worker.log(f'Метод /Execute пропущен: файл обработки не найден: {epf}')
            return False

        self.ensure_dirs()
        out_file = Path(self.app_config.settings.reports_dir) / f'{safe_name(run_base.name)}_metadata_{now_stamp()}.json'

        for f in [
            Path('/tmp/u1c_metadata_probe_result.txt'),
            Path('/tmp/u1c_metadata_probe_result.json'),
            Path('/tmp/updater1c_metadata_probe.json'),
            Path('/tmp/DbInfo.json'),
            Path('/tmp/DbInfo.txt'),
        ]:
            try:
                if f.exists():
                    f.unlink()
            except Exception:
                pass

        probe = epf
        worker.log('Пробую определить конфигурацию через внешнюю обработку /Execute...')
        worker.log(f'Используемая внешняя обработка: {probe}')
        try:
            worker.log(f'SHA256 внешней обработки: {hashlib.sha256(Path(probe).read_bytes()).hexdigest()}')
        except Exception:
            pass

        worker.log('Основной файл результата:')
        worker.log(str(out_file))

        attempts = [
            [
                '/DisableStartupDialogs',
                '/DisableStartupMessages',
                '/Execute', probe,
                f'/CU1C_META_OUT={out_file}'
            ],
            [
                '/DisableStartupDialogs',
                '/DisableStartupMessages',
                f'/CU1C_META_OUT={out_file}',
                '/Execute', probe,
            ],
            [
                '/DisableStartupDialogs',
                '/DisableStartupMessages',
                '/C', f'U1C_META_OUT={out_file}',
                '/Execute', probe,
            ],
        ]

        for attempt_no, extra_args in enumerate(attempts, 1):
            worker.log(f'Запуск DbInfo, попытка {attempt_no}/{len(attempts)}...')
            args = build_1c_args(run_base, 'ENTERPRISE', platform, extra_args)
            run_command_with_timeout(worker, args, timeout=240, allow_error=True)

            name, syn, ver, used_file = parse_any_metadata_probe_output(out_file, worker)
            if self.save_detected_metadata(idx, name, syn, ver, worker):
                if used_file:
                    worker.log(f'Метаданные успешно применены из файла: {used_file}')
                return True

            worker.log(f'Попытка {attempt_no} не дала распознанных метаданных.')

        worker.log('Внешняя обработка не вернула распознанные имя/синоним/версию. Проверь содержимое выведенных файлов результата выше.')
        return False


    def try_metadata_dump(self, worker, run_base: BaseItem, platform: str, idx) -> bool:
        worker.log('Пробую определить конфигурацию и версию через DumpConfigToFiles -Format Plain...')
        worker.log('Иерархическую выгрузку не используем: на типовых конфигурациях она может падать из-за слишком длинных путей.')
        self.ensure_dirs(); log_file = Path(self.app_config.settings.reports_dir) / f'{safe_name(run_base.name)}_DumpConfigToFiles_{now_stamp()}.log'
        short_tmp_root = Path('/tmp/u1c')
        short_tmp_root.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix='c', dir=str(short_tmp_root)) as td:
            args = build_1c_args(
                run_base,
                'DESIGNER',
                platform,
                [
                    '/DisableStartupDialogs',
                    '/DisableStartupMessages',
                    '/DumpConfigToFiles', td,
                    '-Format', 'Plain',
                    '/Out', str(log_file),
                    '-NoTruncate'
                ]
            )
            rc = run_command(worker, args, allow_error=True)
            name, syn, ver = parse_config_dump(Path(td))
            if rc != 0 and not (name or syn or ver):
                worker.log('DumpConfigToFiles завершился с ошибкой, данные из XML определить не удалось.')
                worker.log(f'Лог проверки: {log_file}')
                log_tail = tail_file(log_file)
                if log_tail:
                    worker.log('Хвост лога:')
                    worker.log(log_tail)
                return False
            elif rc != 0:
                worker.log('DumpConfigToFiles вернул ненулевой код, но нужные данные удалось прочитать из выгрузки.')
        if self.save_detected_metadata(idx, name, syn, ver, worker):
            return True
        worker.log('Не удалось прочитать имя/версию из выгрузки. Хвост лога:'); worker.log(tail_file(log_file))
        return False

    def check_one_base(self, worker, base: BaseItem, idx: int):
        run_base = self.prepare_base(base)
        platform = self.resolve_platform_exe(run_base) if run_base.kind != 'web' else None
        method = (self.app_config.settings.metadata_detection_method or 'auto').lower()

        worker.log('')
        worker.log(f'--- Проверка базы: {run_base.name} ---')
        worker.log(f'Тип: {run_base.kind}')
        worker.log(f'Подключение: {run_base.connect}')
        worker.log(f'Метод определения конфигурации: {method}')

        if run_base.kind == 'web':
            worker.log('Web-база: автоопределение через Конфигуратор недоступно. Для web/1cfresh версию лучше заполнить вручную или сделать отдельный механизм внутри опубликованной базы.')
            return

        if method == 'manual':
            worker.log('Метод определения = manual. Автопроверка пропущена, используй поля в свойствах базы.')
            return

        if run_base.kind == 'file' and not Path(run_base.connect).exists():
            worker.log(f'ОШИБКА: папка файловой базы не найдена: {run_base.connect}')
            return

        if run_base.kind == 'server' and '\\' not in run_base.connect:
            worker.log('ПРЕДУПРЕЖДЕНИЕ: ожидается формат server\\infobase')

        if not platform:
            worker.log('ОШИБКА: не найдена платформа 1С.')
            return

        if method == 'execute':
            if not self.try_metadata_execute(worker, run_base, platform, idx):
                worker.log('Метод execute не дал результата. DumpConfigToFiles не запускается, потому что выбран режим execute.')
            return

        if method == 'dump':
            if not self.try_metadata_dump(worker, run_base, platform, idx):
                worker.log('Метод dump не дал результата.')
            return

        if method == 'auto':
            if self.try_metadata_execute(worker, run_base, platform, idx):
                return
            worker.log('Метод /Execute не дал результата. Так как выбран режим auto, пробую fallback через DumpConfigToFiles.')
            if self.try_metadata_dump(worker, run_base, platform, idx):
                return
            worker.log('Автоопределение не удалось. Для Бухгалтерии и крупных типовых баз лучше выбрать метод execute, чтобы не запускать DumpConfigToFiles.')
            return

        worker.log(f'Неизвестный метод определения: {method}. Используй auto/execute/dump/manual.')


