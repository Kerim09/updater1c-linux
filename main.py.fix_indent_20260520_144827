    def group_child_indices(self, group_item):
        result = []
        if not group_item:
            return result
        for i in range(group_item.childCount()):
            child = group_item.child(i)
            idx = child.data(0, Qt.UserRole)
            if isinstance(idx, int):
                result.append(idx)
        return result

    def check_selected_group(self):
        group_item = self.selected_group_item()
        if not group_item:
            QMessageBox.information(self, 'Нет группы', 'Выберите группу или базу внутри группы.')
            return
        self.refreshing_tree = True
        for i in range(group_item.childCount()):
            child = group_item.child(i)
            idx = child.data(0, Qt.UserRole)
            if isinstance(idx, int):
                child.setCheckState(0, Qt.Checked)
                self.checked_base_keys.add(self.base_key(self.app_config.bases[idx]))
        self.refreshing_tree = False

    def uncheck_selected_group(self):
        group_item = self.selected_group_item()
        if not group_item:
            QMessageBox.information(self, 'Нет группы', 'Выберите группу или базу внутри группы.')
            return
        self.refreshing_tree = True
        for i in range(group_item.childCount()):
            child = group_item.child(i)
            idx = child.data(0, Qt.UserRole)
            if isinstance(idx, int):
                child.setCheckState(0, Qt.Unchecked)
                self.checked_base_keys.discard(self.base_key(self.app_config.bases[idx]))
        self.refreshing_tree = False

    def delete_selected_group(self):
        group_item = self.selected_group_item()
        if not group_item:
            QMessageBox.information(self, 'Нет группы', 'Выберите группу для удаления.')
            return

        group_name = group_item.text(0)
        indices = self.group_child_indices(group_item)
        if not indices:
            QMessageBox.information(self, 'Пустая группа', f'В группе «{group_name}» нет баз для удаления.')
            return

        answer = QMessageBox.question(
            self,
            'Удалить группу',
            f'Удалить группу «{group_name}» вместе со всеми базами внутри?\n\n'
            f'Будет удалено из списка баз: {len(indices)}.\n'
            f'Файлы баз на диске не удаляются.',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )
        if answer != QMessageBox.Yes:
            return

        keys_to_remove = {self.base_key(self.app_config.bases[i]) for i in indices}
        for i in sorted(indices, reverse=True):
            del self.app_config.bases[i]

        self.checked_base_keys.difference_update(keys_to_remove)
        self.current_base_index = None
        self.app_config.save()
        self.refresh_tree()
        self.log(f'Удалена группа «{group_name}» из списка баз. Удалено записей: {len(indices)}. Файлы баз на диске не удалялись.')



    def default_ibases_v8i_paths(self):
        home = Path.home()
        candidates = [
            home / '.1C' / '1cestart' / 'ibases.v8i',
            home / '.1C' / '1CEStart' / 'ibases.v8i',
            home / '.1cv8' / '1C' / '1CEStart' / 'ibases.v8i',
            home / '.1cv8' / '1cestart' / 'ibases.v8i',
        ]
        return [p for p in candidates if p.exists()]

    def sync_from_1c_list(self):
        paths = self.default_ibases_v8i_paths()

        if not paths:
            path, _ = QFileDialog.getOpenFileName(
                self,
                'Выберите файл списка баз 1С ibases.v8i',
                str(Path.home()),
                '1C base list (ibases.v8i);;All files (*)'
            )
            if not path:
                return
            paths = [Path(path)]

        path = paths[0]

        try:
            imported = parse_v8i(path)
        except Exception as e:
            QMessageBox.warning(self, 'Ошибка чтения списка 1С', f'Не удалось прочитать:\n{path}\n\n{e}')
            return

        if not imported:
            QMessageBox.information(self, 'Синхронизация с 1С', f'В файле не найдено баз:\n{path}')
            return

        existing_by_key = {}
        existing_by_name_group = {}

        for b in self.app_config.bases:
            existing_by_key[self.base_key(b)] = b
            existing_by_name_group[((b.group or '').strip(), (b.name or '').strip(), (b.kind or '').strip())] = b

        added = 0
        updated = 0
        skipped_groups = 0

        for nb in imported:
            normalize_base(nb)

            if is_group_placeholder_base(nb):
                # Группы в списке 1С не добавляем как базы, они отображаются через поле group
                skipped_groups += 1
                continue

            key = self.base_key(nb)
            ng_key = ((nb.group or '').strip(), (nb.name or '').strip(), (nb.kind or '').strip())

            old = existing_by_key.get(key) or existing_by_name_group.get(ng_key)

            if old:
                old.name = nb.name or old.name
                old.group = nb.group or old.group
                old.kind = nb.kind or old.kind
                old.connect = nb.connect or old.connect
                old.platform_version = nb.platform_version or old.platform_version
                old.launch_parameters = nb.launch_parameters or old.launch_parameters
                old.default_app = getattr(nb, 'default_app', '') or getattr(old, 'default_app', '')
                updated += 1
            else:
                self.app_config.bases.append(nb)
                added += 1

        self.app_config.save()
        self.refresh_tree()

        self.log(
            f'Синхронизация со списком 1С выполнена: {path}\n'
            f'Добавлено баз: {added}, обновлено: {updated}, пропущено групп: {skipped_groups}'
        )

        QMessageBox.information(
            self,
            'Синхронизация с 1С',
            f'Готово.\n\nФайл: {path}\nДобавлено: {added}\nОбновлено: {updated}\nПропущено групп: {skipped_groups}'
        )


    def add_base(self):
        dlg = BaseDialog(self)
        dlg.setWindowTitle('Добавление базы')
        if dlg.exec() != QDialog.Accepted:
            return

        b = dlg.get_base()
        mode = getattr(b, 'add_mode', 'existing')

        if not (b.name or '').strip():
            QMessageBox.warning(self, 'Не заполнено имя', 'Укажите имя базы или группы.')
            return

        if mode == 'group':
            b.kind = 'group'
            b.connect = ''
            self.app_config.bases.append(b)
            self.app_config.save()
            self.refresh_tree()
            self.log(f'Создана группа: {b.name}')
            return

        if mode in ('empty', 'template'):
            ok = self.create_infobase_by_platform(b, mode, getattr(b, 'template_path', ''))
            if not ok:
                return

        self.app_config.bases.append(b)
        self.app_config.save()
        self.refresh_tree()
        self.log(f'Добавлена база: {b.name}')


    def create_infobase_by_platform(self, b: BaseItem, mode: str, template_path: str = '') -> bool:
        import subprocess, shutil, os, tempfile

        if b.kind != 'file':
            QMessageBox.warning(self, 'Пока только file', 'Создание новой базы сейчас реализовано для файловых баз.')
            return False

        path = Path(b.connect).expanduser()
        if not str(path).strip():
            QMessageBox.warning(self, 'Не указан путь', 'Укажите путь к новой файловой базе.')
            return False

        exe = find_platform_exe_for_version(b.platform_version or '8.3')
        if not exe:
            QMessageBox.warning(self, 'Платформа не найдена', 'Не найден исполняемый файл платформы 1С.')
            return False

        path.mkdir(parents=True, exist_ok=True)

        out = Path(self.app_config.settings.reports_dir).expanduser() / f'{safe_name(b.name)}_create_{now_stamp()}.log'
        out.parent.mkdir(parents=True, exist_ok=True)

        env = os.environ.copy()
        env.setdefault('LD_PRELOAD', '/lib/x86_64-linux-gnu/libgcc_s.so.1')

        try:
            self.log(f'Создание информационной базы: {b.name}')
            self.log(f'Путь базы: {path}')

            cmd = [
                exe,
                'CREATEINFOBASE',
                f'File="{path}"',
                '/Out', str(out),
                '-NoTruncate'
            ]

            self.log('Команда создания базы:')
            self.log(' '.join(cmd))

            code = subprocess.call(cmd, env=env)
            if code != 0:
                QMessageBox.warning(self, 'Ошибка создания базы', f'CREATEINFOBASE завершился с кодом {code}.\nЛог: {out}')
                return False

            if mode == 'template' and template_path:
                t = Path(template_path).expanduser()

                if t.is_dir():
                    dt = next(t.rglob('1Cv8.dt'), None) or next(t.rglob('1cv8.dt'), None)
                    cf = next(t.rglob('1Cv8.cf'), None) or next(t.rglob('1cv8.cf'), None)
                    onecd = next(t.rglob('1Cv8.1CD'), None)

                    if dt:
                        cmd = [exe, 'DESIGNER', f'/F{path}', '/RestoreIB', str(dt), '/Out', str(out), '-NoTruncate']
                        self.log('Восстановление .dt из папки шаблона:')
                        self.log(' '.join(cmd))
                        code = subprocess.call(cmd, env=env)
                        if code != 0:
                            QMessageBox.warning(self, 'Ошибка шаблона', f'/RestoreIB завершился с кодом {code}.\nЛог: {out}')
                            return False
                    elif cf:
                        cmd1 = [exe, 'DESIGNER', f'/F{path}', '/LoadCfg', str(cf), '/Out', str(out), '-NoTruncate']
                        cmd2 = [exe, 'DESIGNER', f'/F{path}', '/UpdateDBCfg', '-Dynamic+', '/Out', str(out), '-NoTruncate']
                        self.log('Загрузка .cf из папки шаблона:')
                        self.log(' '.join(cmd1))
                        code = subprocess.call(cmd1, env=env)
                        if code != 0:
                            QMessageBox.warning(self, 'Ошибка шаблона', f'/LoadCfg завершился с кодом {code}.\nЛог: {out}')
                            return False
                        code = subprocess.call(cmd2, env=env)
                        if code != 0:
                            QMessageBox.warning(self, 'Ошибка шаблона', f'/UpdateDBCfg завершился с кодом {code}.\nЛог: {out}')
                            return False
                    elif onecd:
                        shutil.copy2(onecd, path / '1Cv8.1CD')
                        self.log(f'База создана копированием шаблона 1Cv8.1CD: {onecd}')
                    else:
                        QMessageBox.information(self, 'Шаблон', 'В папке шаблона не найден 1Cv8.dt / 1Cv8.cf / 1Cv8.1CD. Создана пустая база.')

                elif t.suffix.lower() == '.dt':
                    cmd = [exe, 'DESIGNER', f'/F{path}', '/RestoreIB', str(t), '/Out', str(out), '-NoTruncate']
                    self.log('Восстановление .dt:')
                    self.log(' '.join(cmd))
                    code = subprocess.call(cmd, env=env)
                    if code != 0:
                        QMessageBox.warning(self, 'Ошибка шаблона', f'/RestoreIB завершился с кодом {code}.\nЛог: {out}')
                        return False

                elif t.suffix.lower() == '.cf':
                    cmd1 = [exe, 'DESIGNER', f'/F{path}', '/LoadCfg', str(t), '/Out', str(out), '-NoTruncate']
                    cmd2 = [exe, 'DESIGNER', f'/F{path}', '/UpdateDBCfg', '-Dynamic+', '/Out', str(out), '-NoTruncate']
                    self.log('Загрузка .cf:')
                    self.log(' '.join(cmd1))
                    code = subprocess.call(cmd1, env=env)
                    if code != 0:
                        QMessageBox.warning(self, 'Ошибка шаблона', f'/LoadCfg завершился с кодом {code}.\nЛог: {out}')
                        return False
                    self.log('Обновление структуры базы:')
                    self.log(' '.join(cmd2))
                    code = subprocess.call(cmd2, env=env)
                    if code != 0:
                        QMessageBox.warning(self, 'Ошибка шаблона', f'/UpdateDBCfg завершился с кодом {code}.\nЛог: {out}')
                        return False

            self.log(f'База создана: {b.name}')
            return True

        except Exception as e:
            QMessageBox.warning(self, 'Ошибка создания базы', str(e))
            return False


    def edit_base(self):
        idx = self.selected_base_index()
        if idx is None: QMessageBox.information(self,'Нет базы','Выберите базу.'); return
        dlg = BaseDialog(self, self.app_config.bases[idx])
