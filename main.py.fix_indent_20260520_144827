def extract_quoted(connect: str, key: str) -> str:
    m = re.search(rf'{key}\s*=\s*"([^"]*)"', connect, flags=re.I)
    if m: return m.group(1)
    m = re.search(rf'{key}\s*=\s*([^;]+)', connect, flags=re.I)
    return m.group(1).strip() if m else ''


def normalize_connect(kind: str, connect: str) -> Tuple[str, str]:
    c = (connect or '').strip()
    low = c.lower()
    if low.startswith('file='):
        return 'file', extract_quoted(c, 'File') or c
    if 'srvr=' in low and 'ref=' in low:
        srv = extract_quoted(c, 'Srvr'); ref = extract_quoted(c, 'Ref')
        return 'server', f'{srv}\\{ref}' if srv and ref else c
    if low.startswith('ws=') or low.startswith('wsurl=') or low.startswith('web='):
        url = extract_quoted(c, 'WS') or extract_quoted(c, 'Ws') or extract_quoted(c, 'WsUrl') or extract_quoted(c, 'Web') or c.split('=', 1)[-1].strip('"; ')
        return 'web', url
    if low.startswith('http://') or low.startswith('https://'):
        return 'web', c.strip('"; ')
    return kind or 'file', c


def normalize_base(base: BaseItem):
    base.kind, base.connect = normalize_connect(base.kind, base.connect)
    if base.kind == 'web' and base.default_app == '':
        base.default_app = 'WebClient'
    if not getattr(base, 'client_mode', ''):
        base.client_mode = 'thin'


def is_group_placeholder_base(base: BaseItem) -> bool:
    """Строка из ibases.v8i, которая на самом деле является папкой/группой, а не базой.

    В ibases.v8i встречаются секции папок без Connect. Раньше они импортировались
    как file-базы с пустым путем и попадали в "Без группы".
    """
    return not (base.connect or '').strip()


def real_base_indices(bases: List[BaseItem]) -> List[int]:
    return [i for i, b in enumerate(bases) if not is_group_placeholder_base(b)]


def remove_group_placeholder_bases(bases: List[BaseItem]) -> int:
    """Удаляет из списка старые записи-группы/папки, ошибочно сохраненные как базы.

    Это нужно для конфигов, которые были созданы старыми версиями приложения:
    раньше секции папок из ibases.v8i могли попасть в список баз и отображаться
    в группе "Без группы".
    """
    before = len(bases)
    bases[:] = [b for b in bases if not is_group_placeholder_base(b)]
    return before - len(bases)



def parse_v8i(path: Path) -> List[BaseItem]:
    text = path.read_text(encoding='utf-8', errors='replace')
    bases, name, cur = [], None, {}
    def flush():
        nonlocal name, cur
        if not name: return
        kv = {k.lower(): v for k, v in cur.items()}
        connect = cur.get('Connect') or kv.get('connect') or ''
        if not (connect or '').strip():
            # Это секция папки/группы в ibases.v8i, а не информационная база.
            # Такие записи не импортируем как базы.
            name, cur = None, {}
            return
        kind, conn_value = normalize_connect('file', connect)
        folder = (cur.get('Folder') or kv.get('folder') or '').strip('/')
        ver = cur.get('DefaultVersion') or cur.get('Version') or kv.get('defaultversion') or kv.get('version') or '8.3'
        addp = cur.get('AdditionalParameters') or kv.get('additionalparameters') or ''
        app = cur.get('App') or kv.get('app') or ''
        if app.lower() == 'webclient' and conn_value.lower().startswith(('http://','https://')):
            kind = 'web'
        b = BaseItem(name=name, group=folder, kind=kind, connect=conn_value, platform_version=ver, launch_parameters=addp, default_app=app)
        normalize_base(b)
        bases.append(b)
        name, cur = None, {}
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith(';'): continue
        if line.startswith('[') and line.endswith(']'):
            flush(); name = line[1:-1].strip(); cur = {}; continue
        if '=' in line and name:
            k, v = line.split('=', 1); cur[k.strip()] = v.strip()
    flush()
    return bases


def quote_param(prefix: str, value: str) -> str:
    return f'{prefix}{value}'


def find_system_libgcc_s() -> Optional[str]:
    """Найти системную libgcc_s.so.1.

    У некоторых платформ 1С в каталоге версии лежит старая libgcc_s.so.1.
    На новых Ubuntu системные библиотеки, например libhwy.so.1, требуют символы
    GCC_12.0.0/GCC_13.0.0, которых нет в старой библиотеке из каталога 1С.
    LD_PRELOAD системной libgcc_s решает этот конфликт без изменения /opt/1cv8.
    """
    candidates = [
        '/lib/x86_64-linux-gnu/libgcc_s.so.1',
        '/usr/lib/x86_64-linux-gnu/libgcc_s.so.1',
        '/lib/i386-linux-gnu/libgcc_s.so.1',
        '/usr/lib/i386-linux-gnu/libgcc_s.so.1',
    ]
    for p in candidates:
        if Path(p).exists():
            return p
    return None


def command_contains_1c_platform(args: List[str]) -> bool:
    for a in args or []:
        low = str(a).lower()
        name = Path(str(a)).name.lower()
        if '/opt/1cv8/' in low or '/opt/1c/' in low:
            if name in ('1cv8', '1cv8c', '1cv8s', '1cestart'):
                return True
    return False


def build_1c_env_for_args(args: List[str], base_env: Optional[dict] = None) -> dict:
    """Окружение для запуска 1С.

    Автоматически подмешивает системную libgcc_s.so.1 через LD_PRELOAD, если
    команда запускает платформу 1С. Это исправляет ошибку:
    libgcc_s.so.1: version `GCC_12.0.0' / `GCC_13.0.0' not found.
    """
    merged = os.environ.copy()
    merged.update(base_env or {})

    if command_contains_1c_platform(args):
        sys_libgcc = find_system_libgcc_s()
        if sys_libgcc:
            old_preload = merged.get('LD_PRELOAD', '').strip()
            parts = [sys_libgcc]
            if old_preload:
                parts.append(old_preload)
            merged['LD_PRELOAD'] = ' '.join(parts)

    return merged


def env_short_text(env: dict) -> str:
    items = []
    for key in ['LD_PRELOAD']:
        val = env.get(key)
        if val:
            items.append(f'{key}={val}')
    return '; '.join(items)



def build_1c_args(base: BaseItem, mode: str, platform_exe: str, extra_args: Optional[List[str]] = None) -> List[str]:
    args = [platform_exe, mode]
    if base.kind == 'server': args.append(quote_param('/S', base.connect))
    elif base.kind == 'file': args.append(quote_param('/F', base.connect))
    elif base.kind == 'web': args.append(quote_param('/WS', base.connect))
    else: raise ValueError(f'Неизвестный тип базы: {base.kind}')
    if base.user: args.append(quote_param('/N', base.user))
    if base.password: args.append(quote_param('/P', base.password))
    if base.launch_parameters: args.extend(shlex.split(base.launch_parameters))
    if extra_args: args.extend(extra_args)
    return args


def command_to_text(args: List[str]) -> str:
    return ' '.join(shlex.quote(x) for x in args)


class OperationCancelled(Exception):
    pass


class OperationWorker(QThread):
    log_signal = Signal(str)
    done_signal = Signal(bool, str)
    refresh_signal = Signal()

    def __init__(self, title: str, work_func):
        super().__init__()
        self.title = title
        self.work_func = work_func
        self.cancel_requested = False

    def log(self, text: str):
        self.log_signal.emit(str(text))

    def request_cancel(self):
        self.cancel_requested = True
        self.log('Запрошена отмена. Текущая команда 1С не прерывается; остановка будет выполнена на ближайшем безопасном этапе.')

    def is_cancel_requested(self) -> bool:
        return bool(self.cancel_requested)

    def check_cancel(self, message: str = 'Операция остановлена пользователем.'):
        if self.cancel_requested:
            raise OperationCancelled(message)

    def run(self):
        try:
            self.log(f'=== {self.title} ===')
            self.work_func(self)
            if self.cancel_requested:
                self.done_signal.emit(True, f'{self.title}: отменено пользователем')
            else:
                self.done_signal.emit(True, f'{self.title}: завершено')
        except OperationCancelled as e:
            self.log(str(e))
            self.done_signal.emit(True, f'{self.title}: отменено пользователем')
        except Exception as e:
            self.log(f'ОШИБКА: {e}')
            self.done_signal.emit(False, f'{self.title}: ошибка')


def run_command(worker: OperationWorker, args: List[str], env: Optional[dict] = None, allow_error=False) -> int:
    worker.log('Команда:'); worker.log(command_to_text(args))
    merged = build_1c_env_for_args(args, env)
    env_text = env_short_text(merged)
    if env_text:
        worker.log('Окружение запуска: ' + env_text)
    p = subprocess.Popen(args, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, errors='replace', bufsize=1, env=merged)
    assert p.stdout
    for line in p.stdout: worker.log(line.rstrip())
    rc = p.wait(); worker.log(f'Код завершения: {rc}')
    if rc != 0 and not allow_error: raise RuntimeError(f'Команда завершилась с кодом {rc}')
    return rc


def tail_file(path: Path, max_lines=250) -> str:
    if not path.exists(): return ''
    return '\n'.join(path.read_text(encoding='utf-8', errors='replace').splitlines()[-max_lines:])


def run_command_with_timeout(worker: OperationWorker, args: List[str], env: Optional[dict] = None, timeout: int = 180, allow_error=False) -> int:
    worker.log('Команда:'); worker.log(command_to_text(args))
    merged = build_1c_env_for_args(args, env)
    env_text = env_short_text(merged)
    if env_text:
        worker.log('Окружение запуска: ' + env_text)
    p = subprocess.Popen(args, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, errors='replace', env=merged)
    try:
        out, _ = p.communicate(timeout=timeout)
    except subprocess.TimeoutExpired:
        p.kill()
        out, _ = p.communicate()
        if out:
            for line in out.splitlines(): worker.log(line)
        worker.log(f'Команда остановлена по таймауту {timeout} сек. Внешняя обработка должна сама закрывать 1С после записи результата.')
        if not allow_error:
            raise RuntimeError('Таймаут выполнения команды')
        return 124
    if out:
        for line in out.splitlines(): worker.log(line)
    rc = p.returncode; worker.log(f'Код завершения: {rc}')
    if rc != 0 and not allow_error: raise RuntimeError(f'Команда завершилась с кодом {rc}')
    return rc



def run_1c_batch(worker: OperationWorker, args: List[str], timeout: int = 7200, hidden_xvfb: bool = False, allow_error: bool = False) -> int:
    """Запуск 1С в пакетном режиме.

    Если включен hidden_xvfb и установлен xvfb-run, команда запускается в виртуальном X-дисплее.
    Это не "нажимает кнопки", а именно не дает интерактивному окну мешать рабочему столу.
    Если платформа зависла на интерактивном вопросе, команда будет остановлена по таймауту.
    """
    final_args = list(args)
    if hidden_xvfb:
        xvfb = shutil.which('xvfb-run')
        if xvfb:
            final_args = [xvfb, '-a', '-s', '-screen 0 1280x1024x24'] + final_args
            worker.log('Скрытый запуск через xvfb-run включен.')
        else:
            worker.log('xvfb-run не найден. Запуск будет обычным. Установить можно: sudo apt install xvfb -y')

    return run_command_with_timeout(worker, final_args, timeout=timeout, allow_error=allow_error)



def find_first_regex(text: str, patterns: List[str]) -> str:
    for p in patterns:
        m = re.search(p, text, flags=re.S | re.I)
        if m:
            val = re.sub(r'<[^>]+>', '', m.group(1)).strip()
            if val: return val
    return ''


def _local_name(tag: str) -> str:
    return tag.split("}", 1)[-1] if "}" in tag else tag


def _children_by_name(elem, name: str):
    return [x for x in list(elem) if _local_name(x.tag) == name]


def _first_child(elem, name: str):
    items = _children_by_name(elem, name)
    return items[0] if items else None


def _child_text(elem, name: str) -> str:
    child = _first_child(elem, name)
    return (child.text or "").strip() if child is not None else ""


def _synonym_text(elem) -> str:
    syn = _first_child(elem, "Synonym")
    if syn is None:
        return ""

    def good(value: str) -> bool:
        v = (value or "").strip()
        if not v:
            return False
        if v.lower() in {"ru", "en", "de", "fr", "language", "content"}:
            return False
        return True

    # Основной формат: Synonym/item/lang + content.
    best = ""
    for item in syn.iter():
        if _local_name(item.tag) == "item":
            lang = _child_text(item, "lang")
            content = _child_text(item, "content")
            if good(content) and lang.lower() == "ru":
                return content.strip()
            if good(content) and not best:
                best = content.strip()
    if best:
        return best

    # Иногда content лежит глубже или с пространствами имен.
    for x in syn.iter():
        if _local_name(x.tag).lower() == "content" and good(x.text or ""):
            return (x.text or "").strip()

    # Последний fallback: все текстовые узлы, но отбрасываем коды языков.
    for x in syn.iter():
        if good(x.text or ""):
            return (x.text or "").strip()

    return ""

def _looks_like_config_name(value: str) -> bool:
    if not value:
        return False
    v = value.strip()
    if v.lower() in {"ru", "en", "language", "common"}:
        return False
    return bool(re.match(r"^[A-Za-zА-Яа-я_][0-9A-Za-zА-Яа-я_]*$", v))


def parse_config_dump(dump_dir: Path) -> Tuple[str, str, str]:
    """Читает имя/синоним/версию конфигурации из DumpConfigToFiles.

    Нельзя брать первый попавшийся <Name>/<Version> из любого XML:
    в выгрузке много файлов, там встречаются языки вроде <Name>ru</Name>.
    Читаем только корневой Configuration.xml и блок Configuration/Properties.
    """
    candidates = []
    root_cfg = dump_dir / "Configuration.xml"
    if root_cfg.exists():
        candidates.append(root_cfg)

    for p in dump_dir.rglob("Configuration.xml"):
        if p not in candidates:
            candidates.append(p)

    for xml_path in candidates:
        try:
            tree = ET.parse(xml_path)
        except Exception:
            continue

        root = tree.getroot()
        cfg = None

        if _local_name(root.tag) == "Configuration":
            cfg = root
        else:
            for elem in root.iter():
                if _local_name(elem.tag) == "Configuration":
                    cfg = elem
                    break

        if cfg is None:
            continue

        props = _first_child(cfg, "Properties") or cfg
        name = _child_text(props, "Name")
        synonym = _synonym_text(props)
        version = _child_text(props, "Version")

        if _looks_like_config_name(name) and version:
            return name, synonym, version

        if version and synonym:
            return "", synonym, version

    return "", "", ""


def is_valid_update_program_name(value: str) -> bool:
    return bool(value and re.match(r"^[A-Za-z0-9_.-]+$", value.strip()))

def guess_update_program_name(base: BaseItem) -> str:
    if is_valid_update_program_name(base.update_program_name):
        return base.update_program_name.strip()

    raw = " ".join([base.config_name, base.config_synonym, base.name]).lower()
    mapping = [
        (["бухгалтер", "accounting", "бухгалтерия предприятия"], "Accounting"),
        (["зарплата", "зуп", "hrm", "управление персоналом"], "HRM"),
        (["управление торговлей", "ут ", "trade"], "Trade"),
        (["розница", "retail"], "Retail"),
        (["документооборот", "document"], "DocumentManagement"),
        (["комплексная автоматизация"], "ComplexAutomation"),
        (["erp"], "EnterpriseERP"),
    ]

    for keys, val in mapping:
        if any(k in raw for k in keys):
            return val

    return ""


def sanitize_update_program_name(value: str) -> str:
    value = (value or "").strip()
    return value if is_valid_update_program_name(value) else ""


def parse_metadata_probe_output(path: Path) -> Tuple[str, str, str]:
    """Читает результат внешней обработки.

    Поддерживаются JSON, вложенный JSON и простой текст key=value/key: value.
    """
    if not path or not path.exists():
        return "", "", ""

    raw = path.read_text(encoding="utf-8-sig", errors="replace").strip()
    if not raw:
        return "", "", ""

    name_keys = {
        "name", "metadataname", "configurationname", "config_name",
        "имя", "имяконфигурации", "техническоеимя", "метаданныеимя"
    }
    synonym_keys = {
        "synonym", "configurationsynonym", "config_synonym",
        "синоним", "синонимконфигурации", "представление", "конфигурация"
    }
    version_keys = {
        "version", "configurationversion", "config_version",
        "версия", "версияконфигурации", "релиз"
    }

    def normalize_key(k):
        return str(k).strip().lower().replace(" ", "").replace("_", "")

    def recursive_pick(obj, wanted_keys):
        if isinstance(obj, dict):
            for k, v in obj.items():
                if normalize_key(k) in wanted_keys and v not in (None, ""):
                    return str(v).strip()
            for v in obj.values():
                found = recursive_pick(v, wanted_keys)
                if found:
                    return found
        elif isinstance(obj, list):
            for v in obj:
                found = recursive_pick(v, wanted_keys)
                if found:
                    return found
        return ""

    try:
        data = json.loads(raw)
        if isinstance(data, dict):
            return (
                recursive_pick(data, name_keys),
                recursive_pick(data, synonym_keys),
                recursive_pick(data, version_keys),
            )
    except Exception:
        pass

    values = {}
    for line in raw.splitlines():
        if "=" in line:
            k, v = line.split("=", 1)
        elif ":" in line:
            k, v = line.split(":", 1)
        else:
            continue
        values[normalize_key(k)] = v.strip()

    def pick_text(keys):
        for k in keys:
            nk = normalize_key(k)
            if nk in values and values[nk]:
                return values[nk]
        return ""

    return (
        pick_text(name_keys),
        pick_text(synonym_keys),
        pick_text(version_keys),
    )


def metadata_probe_candidate_files(out_file: Path) -> List[Path]:
    candidates = [
        out_file,
        Path('/tmp/u1c_metadata_probe_result.txt'),
        Path('/tmp/u1c_metadata_probe_result.json'),
        Path('/tmp/updater1c_metadata_probe.json'),
        Path('/tmp/DbInfo.json'),
        Path('/tmp/DbInfo.txt'),
    ]

    try:
        reports_dir = out_file.parent
        if reports_dir.exists():
            candidates.extend(sorted(reports_dir.glob(f'{out_file.stem}*'), key=lambda p: p.stat().st_mtime, reverse=True))
    except Exception:
        pass

    result = []
    seen = set()
    for p in candidates:
        key = str(p)
        if key not in seen:
            seen.add(key)
            result.append(p)
    return result


def parse_any_metadata_probe_output(out_file: Path, worker=None) -> Tuple[str, str, str, str]:
    existing = []
    for candidate in metadata_probe_candidate_files(out_file):
        try:
            if candidate.exists() and candidate.is_file():
                existing.append(candidate)
                name, syn, ver = parse_metadata_probe_output(candidate)
                if name or syn or ver:
                    if worker:
                        worker.log(f'Результат DbInfo прочитан из файла: {candidate}')
                    return name, syn, ver, str(candidate)
        except Exception as e:
            if worker:
                worker.log(f'Не удалось прочитать файл результата {candidate}: {e}')

    if worker:
        if existing:
            worker.log('Файлы результата DbInfo найдены, но имя/синоним/версия не распознаны.')
            for p in existing[:5]:
                try:
                    raw = p.read_text(encoding='utf-8-sig', errors='replace')
                    worker.log(f'--- Содержимое {p} ---')
                    worker.log(raw[:2000] if raw else '<пустой файл>')
                except Exception as e:
                    worker.log(f'Не удалось вывести содержимое {p}: {e}')
        else:
            worker.log('Файл результата DbInfo не найден ни по основному, ни по fallback-путям.')

    return "", "", "", ""



def normalize_detected_metadata(name: str, synonym: str, version: str) -> Tuple[str, str, str]:
    name = (name or "").strip()
    synonym = (synonym or "").strip()
    version = (version or "").strip()
    if not _looks_like_config_name(name):
        name = ""
    if synonym.lower() in {"ru", "en", "de", "fr"}:
        synonym = ""
    return name, synonym, version


def api_platform_version(base: Optional[BaseItem] = None) -> str:
    """Версия платформы для update-api.

    update-api требует конкретную platformVersion. Если у базы стоит просто 8.3,
    берем самую свежую установленную платформу, а если платформы не найдены —
    используем дефолт из клиента v8platform/updateApiClient.
    """
    value = (base.platform_version if base else '') or ''
    value = value.strip()
    if value and not is_generic_platform_version(value):
        return value
    platforms = find_platforms()
    if platforms:
        return next(iter(platforms.keys()))
    return '8.3.3.641'


def safe_update_subpath(value: str, fallback: str = 'update') -> Path:
    value = (value or '').strip().replace('\\', '/')
    if not value:
        value = fallback
    parts = []
    for part in value.split('/'):
        part = part.strip()
        if not part or part in ('.', '..'):
            continue
        parts.append(safe_name(part))
    return Path(*parts) if parts else Path(fallback)



def update_release_folder(value: str, fallback: str = 'release') -> str:
    """Имя папки релиза обновления.

    API часто возвращает templatePath вида 1c/Accounting/3_0_197_22.
    Для хранения в Linux-обновляторе оставляем только последнюю часть:
    <updates_dir>/<Program>/3_0_197_22.
    """
    v = (value or '').strip().replace('\\', '/')
    if '/' in v:
        v = v.rstrip('/').split('/')[-1]
    if not v:
        v = fallback
    return safe_name(v.replace('.', '_'))


def version_to_update_folder(version: str) -> str:
    return safe_name((version or '').strip().replace('.', '_'))


def update_program_dir(settings: Settings, program: str) -> Path:
    return Path(settings.updates_dir) / safe_name(program)


def find_update_file_in_dir(folder: Path) -> Optional[Path]:
    if not folder or not folder.exists():
        return None
    preferred = [folder / '1cv8.cfu', folder / '1CV8.CFU', folder / '1cv8.cf', folder / '1CV8.CF']
    for p in preferred:
        if p.exists() and p.is_file():
            return p
    files = list(folder.rglob('*.cfu')) + list(folder.rglob('*.CFU')) + list(folder.rglob('*.cf')) + list(folder.rglob('*.CF'))
    files = [p for p in files if p.is_file()]
    files.sort(key=lambda p: (0 if p.name.lower() == '1cv8.cfu' else 1, len(str(p)), str(p)))
    return files[0] if files else None


def load_latest_update_info(program_dir: Path) -> dict:
    for p in [program_dir / 'latest_update_info.json'] + sorted((program_dir / '_metadata').glob('update_info_*.json') if (program_dir / '_metadata').exists() else [], key=lambda x: x.stat().st_mtime, reverse=True):
        try:
            if p.exists():
                return json.loads(p.read_text(encoding='utf-8'))
        except Exception:
            pass
    return {}


def find_downloaded_update_steps(settings: Settings, program: str, current_version: str = '') -> List[Tuple[str, Path, Path]]:
    """Возвращает последовательность скачанных релизов: (версия/папка, файл .cfu/.cf, папка).

    Сначала используем latest_update_info.json и upgradeSequence, чтобы сохранять порядок API.
    Если метаданных нет — сканируем папки и сортируем по версии.
    Поддерживает и новый плоский layout, и старый layout .../1c/Accounting/<release>.
    """
    root = update_program_dir(settings, program)
    if not root.exists():
        return []

    info = load_latest_update_info(root)
    seq = []
    if isinstance(info, dict):
        seq = (info.get('info') or {}).get('upgradeSequence') or info.get('upgradeSequence') or []

    result = []
    used = set()

    def add_release(ver):
        folder_name = update_release_folder(str(ver), str(ver))
        candidates = [root / folder_name]
        # Старый layout: Accounting/3.0.185.19_to_.../1c/Accounting/3_0_197_22
        candidates.extend([p for p in root.rglob(folder_name) if p.is_dir() and '_archives' not in p.parts and '_metadata' not in p.parts])
        for folder in candidates:
            key = str(folder.resolve()) if folder.exists() else str(folder)
            if key in used:
                continue
            f = find_update_file_in_dir(folder)
            if f:
                used.add(key)
                result.append((folder_name, f, folder))
                return True
        return False

    for ver in seq:
        add_release(ver)

    if result:
        return result

    dirs = []
    for p in root.iterdir():
        if p.is_dir() and not p.name.startswith('_'):
            f = find_update_file_in_dir(p)
            if f:
                dirs.append((p.name, f, p))
    dirs.sort(key=lambda x: version_key(x[0].replace('_', '.')))
    return dirs


def collect_platform_candidates(obj, inherited=None) -> List[dict]:
    """Достает все возможные distributionUin из произвольного ответа update-api."""
    inherited = dict(inherited or {})
    result = []
    if isinstance(obj, dict):
        cur = dict(inherited)
        for k in ['platformVersion','version','name','title','type','os','architecture','distributionName','distributionType','size','releaseUrl','transitionInfoUrl','recommended']:
            if k in obj and obj.get(k) not in (None, ''):
                cur[k] = obj.get(k)
        uin = obj.get('distributionUin') or obj.get('platformDistributionUin') or obj.get('uin')
        if uin:
            item = dict(cur)
            item['distributionUin'] = uin
            result.append(item)
        for v in obj.values():
            result.extend(collect_platform_candidates(v, cur))
    elif isinstance(obj, list):
        for v in obj:
            result.extend(collect_platform_candidates(v, inherited))
    # unique
    out=[]; seen=set()
    for x in result:
        u=x.get('distributionUin')
        if u and u not in seen:
            seen.add(u); out.append(x)
    return out


def unzip_1c_zip(src: Path, dest: Path):
    """Распаковка zip с учетом старых 1С-архивов с CP866 именами.

    В Go-клиенте v8platform/updateApiClient при NonUTF8 применяется CP866.
    В Python аналог: если UTF-8 flag не установлен, перекодируем cp437 -> cp866.
    """
    dest.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(src) as z:
        for info in z.infolist():
            name = info.filename
            if not (info.flag_bits & 0x800):
                try:
                    name = name.encode('cp437').decode('cp866')
                except Exception:
                    pass
            name = name.replace('\\', '/')
            out_path = dest / safe_update_subpath(name, 'file')
            if info.is_dir():
                out_path.mkdir(parents=True, exist_ok=True)
                continue
            out_path.parent.mkdir(parents=True, exist_ok=True)
            with z.open(info) as src_f, out_path.open('wb') as dst_f:
                shutil.copyfileobj(src_f, dst_f)



def looks_like_release_folder_name(value: str) -> bool:
    v = (value or '').strip().replace('.', '_')
    return bool(re.match(r'^\d+_\d+_\d+(?:_\d+)?$', v))


def detect_release_folder_name(update_file: Path, fallback: str = '') -> str:
    for part in reversed(update_file.parent.parts):
        if looks_like_release_folder_name(part):
            return update_release_folder(part, part)
    return update_release_folder(fallback or update_file.parent.name, fallback or update_file.parent.name)


def normalize_extracted_update_tree(worker, program_dir: Path, extracted_root: Path, fallback_release: str = '') -> List[Path]:
    """Превращает любую структуру архива 1С в плоскую структуру:
    <updates_dir>/<Program>/<release>/1cv8.cfu

    1С часто упаковывает обновления как 1c/<Program>/<release>/...
    Иногда один архив содержит несколько релизов. Поэтому после распаковки ищем
    папки, где лежит .cfu/.cf, и переносим каждую такую папку в корень программы.
    """
    normalized = []

    if not extracted_root.exists():
        return normalized

    update_files = []
    for pattern in ('*.cfu', '*.CFU', '*.cf', '*.CF'):
        update_files.extend([p for p in extracted_root.rglob(pattern) if p.is_file()])

    # Если в корне сразу есть 1cv8.cfu/1cv8.cf — оставляем папку как папку релиза.
    direct = find_update_file_in_dir(extracted_root)
    if direct and direct.parent == extracted_root:
        rel_name = update_release_folder(fallback_release or extracted_root.name, extracted_root.name)
        final_dir = program_dir / rel_name
        if extracted_root.resolve() != final_dir.resolve():
            if final_dir.exists():
                shutil.rmtree(final_dir)
            shutil.copytree(extracted_root, final_dir)
            try:
                shutil.rmtree(extracted_root)
            except Exception:
                pass
            worker.log(f'Папка релиза нормализована: {final_dir}')
            normalized.append(final_dir)
        else:
            worker.log(f'Папка релиза уже в правильном месте: {final_dir}')
            normalized.append(final_dir)
        return normalized

    folders = []
    seen = set()
    for f in update_files:
        folder = f.parent
        key = str(folder.resolve())
        if key not in seen:
            seen.add(key)
            folders.append(folder)

    if not folders:
        worker.log(f'В распакованном архиве не найдены .cfu/.cf: {extracted_root}')
        return normalized

    for folder in folders:
        cfu = find_update_file_in_dir(folder)
        if not cfu:
            continue

        rel_name = detect_release_folder_name(cfu, fallback_release)
        final_dir = program_dir / rel_name

        # Если файл лежит глубоко внутри временной папки 1c/Accounting/<release>, переносим только папку релиза.
        if final_dir.exists():
            shutil.rmtree(final_dir)

        shutil.copytree(folder, final_dir)
        normalized.append(final_dir)
        worker.log(f'Релиз вынесен в плоскую папку: {final_dir}')
        found = find_update_file_in_dir(final_dir)
        if found:
            worker.log(f'Файл обновления в релизе: {found}')

    # Если это была временная папка или старая длинная папка без полезных файлов в корне — удаляем.
    try:
        if extracted_root.exists() and extracted_root.is_dir():
            shutil.rmtree(extracted_root)
            worker.log(f'Временная длинная папка распаковки удалена: {extracted_root}')
    except Exception as e:
        worker.log(f'Не удалось удалить временную папку распаковки {extracted_root}: {e}')

    # Убираем дубли.
    out = []
    seen = set()
    for p in normalized:
        key = str(p)
        if key not in seen:
            seen.add(key)
            out.append(p)
    return out


def cleanup_old_long_update_layout(worker, settings: Settings, program: str):
    """Миграция уже скачанных старых папок вида
    <Program>/3.0.x_to_3.0.y/1c/<Program>/<release> в <Program>/<release>.
    """
    root = update_program_dir(settings, program)
    if not root.exists():
        return

    for p in list(root.iterdir()):
        if not p.is_dir() or p.name.startswith('_'):
            continue
        if '_to_' not in p.name and not (p / '1c').exists():
            continue

        moved = normalize_extracted_update_tree(worker, root, p, '')
        if moved:
            worker.log(f'Старая длинная структура перенесена из {p}.')


def verify_hash_if_possible(path: Path, expected: str) -> Tuple[bool, str]:
    expected = (expected or '').strip().lower()
    if not expected:
        return True, ''
    try:
        if len(expected) == 32:
            import hashlib as _hashlib
            h = _hashlib.md5(path.read_bytes()).hexdigest().lower()
            return h == expected, f'md5={h}'
        if len(expected) == 64:
            import hashlib as _hashlib
            h = _hashlib.sha256(path.read_bytes()).hexdigest().lower()
            return h == expected, f'sha256={h}'
    except Exception as e:
        return False, str(e)
    return True, 'unknown hash format'

class OneCUpdateApi:
    BASE_URL = 'https://update-api.1c.ru'
    USER_AGENT = '1C+Enterprise/8.3'

    UPDATE_INFO_PATH = '/update-platform/programs/update/info'
    UPDATE_PATH = '/update-platform/programs/update/'

    UPDATE_TYPE_WORKING = 'NewConfigurationAndOrPlatform'
    UPDATE_TYPE_PROGRAM_OR_REDACTION = 'NewProgramOrRedaction'
    UPDATE_TYPE_PLATFORM = 'NewPlatform'

    def __init__(self, login: str, password: str):
        self.login = login
        self.password = password
        self.session = requests.Session()
        self.session.headers.update({
            'Content-Type': 'application/json',
            'User-Agent': self.USER_AGENT,
        })

    def _post_path(self, path: str, data: dict) -> dict:
        url = self.BASE_URL + path
        r = self.session.post(url, json=data, timeout=120)
        if r.status_code >= 400:
            raise RuntimeError(f'HTTP {r.status_code}: {r.text[:800]}')
        try:
            result = r.json()
        except Exception:
            raise RuntimeError(f'Ответ update-api не JSON: {r.text[:800]}')
        if result.get('errorName'):
            raise RuntimeError(f"{result.get('errorName')}: {result.get('errorMessage')}")
        return result

    def get_update_info(self, program: str, version: str, update_type: str, platform_version: str) -> dict:
        # В github.com/v8platform/updateApiClient структура UpdateInfoRequest содержит
        # анонимно встроенный ProgramVersion, поэтому JSON уходит НЕ так:
        #   {"programVersion": {"programName": "...", "versionNumber": "..."}}
        # а плоско:
        #   {"programName": "...", "versionNumber": "...", "updateType": "...", "platformVersion": "..."}
        #
        # Именно поэтому старый вариант давал HTTP 400:
        # NotBlank.programUpdateInfoRequest.programName / versionNumber.
        body = {
            'programName': (program or '').strip(),
            'versionNumber': (version or '').strip(),
            'updateType': update_type,
            'platformVersion': (platform_version or '').strip() or '8.3.3.641',
        }
        return self._post_path(self.UPDATE_INFO_PATH, body)


    def check_conf_update(self, program: str, version: str, platform_version: str, allow_next_redaction: bool = False) -> dict:
        update_type = self.UPDATE_TYPE_PROGRAM_OR_REDACTION if allow_next_redaction else self.UPDATE_TYPE_WORKING
        full = self.get_update_info(program, version, update_type, platform_version)
        return full.get('configurationUpdateResponse') or {}

    def check_platform_update(self, program: str, version: str, platform_version: str) -> dict:
        # Сначала просим именно новую платформу. Если API не вернет блок —
        # пробуем рабочее обновление, потому что оно тоже может содержать platformUpdateResponse.
        full = self.get_update_info(program, version, self.UPDATE_TYPE_PLATFORM, platform_version)
        info = full.get('platformUpdateResponse') or {}
        if not info:
            full = self.get_update_info(program, version, self.UPDATE_TYPE_WORKING, platform_version)
            info = full.get('platformUpdateResponse') or {}
        return info

    def get_conf_download_data(self, upgrade_sequence: List[str], program_uin: str) -> List[dict]:
        body = {
            'programVersionUin': program_uin,
            'upgradeSequence': upgrade_sequence,
            'platformDistributionUin': '',
            'login': self.login,
            'password': self.password,
        }
        return self._post_path(self.UPDATE_PATH, body).get('configurationUpdateDataList') or []

    def get_platform_download_data(self, platform_distribution_uin: str) -> dict:
        body = {
            'programVersionUin': '',
            'upgradeSequence': [],
            'platformDistributionUin': platform_distribution_uin,
            'login': self.login,
            'password': self.password,
        }
        return self._post_path(self.UPDATE_PATH, body)

    def download_file(self, url: str, dest: Path, worker: OperationWorker):
        dest.parent.mkdir(parents=True, exist_ok=True)
        with requests.get(
            url,
            headers={'User-Agent': self.USER_AGENT},
            auth=(self.login, self.password),
            timeout=300,
            stream=True,
        ) as r:
            if r.status_code >= 400:
                raise RuntimeError(f'HTTP {r.status_code} при скачивании: {r.text[:800]}')
            total = int(r.headers.get('Content-Length') or 0)
            done = 0
            last = 0
            with dest.open('wb') as f:
                for chunk in r.iter_content(1024 * 512):
                    if not chunk:
                        continue
                    f.write(chunk)
                    done += len(chunk)
                    if total and done - last > 10 * 1024 * 1024:
                        worker.log(f'Скачано {done//1024//1024} из {total//1024//1024} МБ')
                        last = done
        worker.log(f'Файл скачан: {dest}')



