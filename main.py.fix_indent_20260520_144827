    def template_roots(self):
        home = Path.home()
        roots = [
            home / '.1C' / '1cestart' / 'tmplts',
            home / '.1C' / '1CEStart' / 'tmplts',
            home / '.1cv8' / '1C' / '1CEStart' / 'tmplts',
            home / '1c' / 'tmplts',
            Path('/usr/share/1c/tmplts'),
            Path('/opt/1cv8/tmplts'),
        ]

        cfgs = [
            home / '.1C' / '1cestart' / '1cestart.cfg',
            home / '.1C' / '1CEStart' / '1cestart.cfg',
            home / '.1cv8' / '1C' / '1CEStart' / '1cestart.cfg',
        ]

        for cfg in cfgs:
            if cfg.exists():
                try:
                    txt = cfg.read_text(encoding='utf-8', errors='ignore')
                    for line in txt.splitlines():
                        if '=' in line and any(k in line.lower() for k in ['tmpl', 'template', 'commoncfglocation']):
                            val = line.split('=', 1)[1].strip().strip('"')
                            if val:
                                roots.append(Path(val).expanduser())
                except Exception:
                    pass

        return [r for r in dict.fromkeys(roots) if r.exists()]

    def read_template_meta(self, folder: Path):
        name = folder.name
        version = ''
        mft = folder / '1cv8.mft'
        if mft.exists():
            try:
                txt = mft.read_text(encoding='utf-8', errors='ignore')
                for line in txt.splitlines():
                    low = line.lower()
                    if low.startswith('name=') or low.startswith('caption='):
                        name = line.split('=', 1)[1].strip().strip('"') or name
                    elif low.startswith('version='):
                        version = line.split('=', 1)[1].strip().strip('"')
            except Exception:
                pass
        return name, version

    def load_templates(self):
        self.tree.clear()
        roots = self.template_roots()

        for root in roots:
            root_item = QTreeWidgetItem([str(root), '', '', str(root)])
            root_item.setData(0, Qt.UserRole, '')
            self.tree.addTopLevelItem(root_item)

            candidates = []
            for marker in ['1cv8.mft', '1Cv8.dt', '1Cv8.cf', '1cv8.dt', '1cv8.cf']:
                candidates.extend(root.rglob(marker))

            folders = sorted({c.parent for c in candidates}, key=lambda x: str(x).lower())

            for folder in folders:
                name, version = self.read_template_meta(folder)

                payload = ''
                for fn in ['1Cv8.dt', '1cv8.dt', '1Cv8.cf', '1cv8.cf']:
                    f = folder / fn
                    if f.exists():
                        payload = str(f)
                        break
                if not payload:
                    payload = str(folder)

                kind, kind_title = self.guess_template_kind(folder, name)
            item = QTreeWidgetItem([name, kind_title, version, str(folder)])
            item.setData(1, Qt.UserRole, kind)
                item.setData(0, Qt.UserRole, payload)
                root_item.addChild(item)

        self.tree.expandAll()

    def choose_root(self):
        path = QFileDialog.getExistingDirectory(self, 'Выберите папку шаблонов 1С')
        if not path:
            return
        root = Path(path)

        root_item = QTreeWidgetItem([str(root), '', '', str(root)])
        root_item.setData(0, Qt.UserRole, '')
        self.tree.addTopLevelItem(root_item)

        folders = sorted({c.parent for c in list(root.rglob('1cv8.mft')) + list(root.rglob('1Cv8.dt')) + list(root.rglob('1Cv8.cf'))})
        for folder in folders:
            name, version = self.read_template_meta(folder)
            payload = ''
            for fn in ['1Cv8.dt', '1cv8.dt', '1Cv8.cf', '1cv8.cf']:
                f = folder / fn
                if f.exists():
                    payload = str(f)
                    break
            if not payload:
                payload = str(folder)
            kind, kind_title = self.guess_template_kind(folder, name)
            item = QTreeWidgetItem([name, kind_title, version, str(folder)])
            item.setData(1, Qt.UserRole, kind)
            item.setData(0, Qt.UserRole, payload)
            root_item.addChild(item)

        root_item.setExpanded(True)

    def accept_selected(self):
        item = self.tree.currentItem()
        if not item:
            return
        payload = item.data(0, Qt.UserRole)
        if not payload:
            return
        self.selected_template = payload
        self.selected_template_kind = item.data(1, Qt.UserRole) or ''
        self.selected_template_name = item.text(0)
        self.selected_template_version = item.text(2)
        self.accept()


