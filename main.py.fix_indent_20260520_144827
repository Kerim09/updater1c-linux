    def make_pre_update_backup(self, worker, base: BaseItem, platform: str, vals: dict) -> Optional[Path]:
        if not vals.get('make_backup'):
            worker.log('Резервная копия перед обновлением отключена пользователем.')
            return None
        backup_type = vals.get('backup_type', 0)
        if backup_type == 2:
            return self.make_dt_backup(worker, base, platform)
        if backup_type == 1:
            return self.make_native_backup(worker, base)
        # auto
        if base.kind == 'file':
            return self.make_file_1cd_backup(worker, base)
        if base.kind == 'server':
            return self.make_dt_backup(worker, base, platform)
        return None

    def restore_pre_update_backup(self, worker, base: BaseItem, platform: str, backup_file: Optional[Path]):
        if not backup_file:
            worker.log('Откат невозможен: резервная копия не создавалась.')
            return
        p = Path(backup_file)
        if base.kind == 'file' and p.name.lower().endswith('.tar.gz'):
            self.restore_file_1cd_backup(worker, base, p)
            return
        if p.suffix.lower() == '.dt':
            log_file = Path(self.app_config.settings.reports_dir) / f'{safe_name(base.name)}_RestoreIB_{now_stamp()}.log'
            worker.log(f'Откат через /RestoreIB из {p}')
            run_command(worker, build_1c_args(base, 'DESIGNER', platform, ['/RestoreIB', str(p), '/Out', str(log_file), '-NoTruncate']))
            worker.log(tail_file(log_file))
            return
        worker.log(f'Автооткат для типа копии {p} пока не выполняется автоматически. Используй эту копию для ручного восстановления.')

    def update_base_version_after_release(self, idx: int, prepared_base: BaseItem, release_version: str, worker: OperationWorker):
        new_version = (release_version or '').replace('_', '.').strip()
        if not new_version:
            return

        # Обновляем и объект в списке, и подготовленную копию, чтобы следующий релиз
        # сравнивался уже с актуальной версией.
        prepared_base.config_version = new_version

        try:
            if idx is not None and 0 <= idx < len(self.app_config.bases):
                b = self.app_config.bases[idx]
            else:
                b = None

            if b is None or b.name != prepared_base.name:
                for candidate in self.app_config.bases:
                    if candidate.name == prepared_base.name and candidate.connect == prepared_base.connect:
                        b = candidate
                        break

            if b is not None:
                b.config_version = new_version
                self.app_config.save()
                worker.refresh_signal.emit()
                worker.log(f'Версия конфигурации в карточке базы обновлена: {new_version}')
            else:
                worker.log(f'Не удалось найти базу в списке для записи версии {new_version}.')
        except Exception as e:
            worker.log(f'Не удалось сохранить новую версию конфигурации {new_version}: {e}')


