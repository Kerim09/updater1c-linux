                except Exception as e:
                    worker.log(f'ОШИБКА для базы {base.name}: {e}')

        self.start_worker(f'Резервная копия .dt: {self.target_label(targets)}', work)

    def get_platform_candidates_for_base(self, base: BaseItem, settings: Settings) -> Tuple[dict, List[dict]]:
        run_base = self.prepare_base(base)
        program = guess_update_program_name(run_base)
        version = run_base.config_version.strip()
        platform_version = api_platform_version(run_base)
        if not program or not version:
            raise RuntimeError('Для запроса новой платформы нужны код программы обновлений и версия конфигурации.')
        api = OneCUpdateApi(settings.its_login, settings.its_password)
        full = api.get_update_info(program, version, api.UPDATE_TYPE_PLATFORM, platform_version)
        info = full.get('platformUpdateResponse') or {}
        if not info:
            full = api.get_update_info(program, version, api.UPDATE_TYPE_WORKING, platform_version)
            info = full.get('platformUpdateResponse') or {}
        candidates = collect_platform_candidates(info)
        return info, candidates

    def download_platform_candidate(self, worker, api: OneCUpdateApi, settings: Settings, candidate: dict, requested_version: str = ''):
        uin = candidate.get('distributionUin') or ''
        if not uin:
            worker.log(f'Пропуск кандидата без distributionUin: {candidate}')
            return
        data = api.get_platform_download_data(uin)
        url = data.get('platformDistributionUrl')
        if not url:
            worker.log(f'ПРОПУСК: API не вернул platformDistributionUrl. Ответ: {data}')
            return
        ver = candidate.get('platformVersion') or candidate.get('version') or requested_version or 'platform'
        title = candidate.get('distributionName') or candidate.get('title') or candidate.get('name') or 'distribution'
        out_dir = Path(settings.platform_download_dir) / safe_name(str(ver)) / safe_name(str(title))
        out_dir.mkdir(parents=True, exist_ok=True)
        file_name = Path(url.split('?', 1)[0]).name or f'1c_platform_{safe_name(str(ver))}.zip'
        dest = out_dir / file_name
        (out_dir / 'platform_download_info.json').write_text(json.dumps({'candidate': candidate, 'download': data}, ensure_ascii=False, indent=2), encoding='utf-8')
        worker.log(f'Скачивание платформы: {url}')
        api.download_file(url, dest, worker)
        if zipfile.is_zipfile(dest):
            extract_dir = out_dir / 'extracted'
            unzip_1c_zip(dest, extract_dir)
            worker.log(f'Платформа распакована: {extract_dir}')
        worker.log(f'Готово. Папка платформы: {out_dir}')

    def download_platform_for_base(self, worker, base: BaseItem, settings: Settings, selected_candidates: Optional[List[dict]] = None, requested_types: Optional[List[str]] = None, requested_version: str = ''):
        run_base = self.prepare_base(base)
        program = guess_update_program_name(run_base)
        version = run_base.config_version.strip()
        platform_version = api_platform_version(run_base)

        worker.log('')
        worker.log(f'--- Скачивание платформы для базы: {run_base.name} ---')
        worker.log(f'Код программы обновлений: {program or "<не заполнен>"}')
        worker.log(f'Версия конфигурации: {version or "<не заполнена>"}')
        worker.log(f'Текущая/выбранная версия платформы: {platform_version}')
        if requested_types:
            worker.log('Запрошенные типы дистрибутивов: ' + ', '.join(requested_types))

        if not program or not version:
            worker.log('ПРОПУСК: для запроса новой платформы нужны код программы обновлений и версия конфигурации.')
            return

        api = OneCUpdateApi(settings.its_login, settings.its_password)
        candidates = selected_candidates
        if candidates is None:
            info, candidates = self.get_platform_candidates_for_base(run_base, settings)
            worker.log(f'Ответ platformUpdateResponse: {json.dumps(info, ensure_ascii=False)[:2000]}')

        if not candidates:
            worker.log('API не вернул доступных distributionUin для скачивания платформы.')
            return

        for n, c in enumerate(candidates, 1):
            worker.log('')
            worker.log(f'Дистрибутив {n}/{len(candidates)}: {json.dumps(c, ensure_ascii=False)}')
            self.download_platform_candidate(worker, api, settings, c, requested_version)

    def download_platform_selected(self):
        targets = self.require_targets()
        if targets is None:
