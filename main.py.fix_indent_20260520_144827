class AppConfig:
    def __init__(self):
        self.settings = Settings(
            updates_dir=str(Path.home() / '1c-updates'),
            platform_download_dir=str(Path.home() / '1c-platforms'),
            backup_dir=str(Path.home() / '1c-backups'),
            reports_dir=str(Path.home() / '1c-update-reports'),
        )
        self.bases: List[BaseItem] = []
        if is_stale_metadata_probe_path(self.settings.metadata_probe_path):
            self.settings.metadata_probe_path = bundled_metadata_probe_path()

    def load(self):
        APP_DIR.mkdir(parents=True, exist_ok=True)
        if not CONFIG_PATH.exists():
            self.save(); return
        data = json.loads(CONFIG_PATH.read_text(encoding='utf-8'))
        merged = asdict(self.settings); merged.update(data.get('settings', {}))
        self.settings = dataclass_from_dict(Settings, merged)
        self.bases = [dataclass_from_dict(BaseItem, x) for x in data.get('bases', [])]
        if is_stale_metadata_probe_path(self.settings.metadata_probe_path):
            self.settings.metadata_probe_path = bundled_metadata_probe_path()
        elif not Path(self.settings.metadata_probe_path).exists():
            bundled = bundled_metadata_probe_path()
            if bundled:
                self.settings.metadata_probe_path = bundled

        for b in self.bases:
            normalize_base(b)
            b.update_program_name = sanitize_update_program_name(b.update_program_name)
            if not _looks_like_config_name(b.config_name):
                b.config_name = ""

    def save(self):
        APP_DIR.mkdir(parents=True, exist_ok=True)
        CONFIG_PATH.write_text(json.dumps({
            'settings': asdict(self.settings),
            'bases': [asdict(x) for x in self.bases],
        }, ensure_ascii=False, indent=2), encoding='utf-8')


class ClipboardLineEdit(QLineEdit):
    """QLineEdit с устойчивой вставкой/копированием.

    На Linux/Wayland стандартная вставка Qt иногда не получает текст из
    системного буфера. Поэтому порядок такой:
    1. пробуем штатный self.paste();
    2. если поле не изменилось — читаем буфер через Qt mimeData/text;
    3. если пусто — пробуем wl-paste/xclip/xsel.
    """
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)

    def _clipboard_text(self) -> str:
        cb = QApplication.clipboard()

        variants = []
        try:
            md = cb.mimeData()
            if md and md.hasText():
                variants.append(md.text())
        except Exception:
            pass

        try:
            variants.append(cb.text())
        except Exception:
            pass

        try:
            variants.append(cb.text(mode=cb.Mode.Clipboard))
        except Exception:
            pass

        try:
            variants.append(cb.text(mode=cb.Mode.Selection))
        except Exception:
            pass

        for value in variants:
            if value:
                return value

        commands = (
            ["wl-paste", "--no-newline"],
            ["wl-paste", "-n"],
            ["wl-paste"],
            ["xclip", "-selection", "clipboard", "-o"],
            ["xclip", "-selection", "primary", "-o"],
            ["xclip", "-o"],
            ["xsel", "-b", "-o"],
            ["xsel", "-p", "-o"],
            ["xsel", "-o"],
        )

        for cmd in commands:
            try:
                out = subprocess.check_output(cmd, stderr=subprocess.DEVNULL, timeout=1)
                value = out.decode("utf-8", errors="replace")
                if value:
                    return value
            except Exception:
                pass

        return ""

    def force_paste(self, *args):
        if self.isReadOnly():
            return

        old_text = self.text()
        old_pos = self.cursorPosition()

        # Сначала пробуем штатный механизм Qt — он иногда работает лучше,
        # чем ручное чтение QApplication.clipboard().
        try:
            self.paste()
            if self.text() != old_text or self.cursorPosition() != old_pos:
                return
        except Exception:
            pass

        value = self._clipboard_text()
        if value:
            self.insert(value)

    def force_copy(self, *args):
        try:
            self.copy()
        except Exception:
            pass

    def force_cut(self, *args):
        try:
            self.cut()
        except Exception:
            pass

    def keyPressEvent(self, event):
        if event.matches(QKeySequence.Paste):
            self.force_paste()
            return
        if event.matches(QKeySequence.Copy):
            self.force_copy()
            return
        if event.matches(QKeySequence.Cut):
            self.force_cut()
            return
        if event.matches(QKeySequence.SelectAll):
            self.selectAll()
            return
        super().keyPressEvent(event)

    def contextMenuEvent(self, event):
        menu = QMenu(self)

        a_undo = menu.addAction("Отменить")
        a_undo.setShortcut("Ctrl+Z")

        a_redo = menu.addAction("Повторить")
        a_redo.setShortcut("Ctrl+Shift+Z")

        menu.addSeparator()

        a_cut = menu.addAction("Вырезать")
        a_cut.setShortcut("Ctrl+X")

        a_copy = menu.addAction("Копировать")
        a_copy.setShortcut("Ctrl+C")

        a_paste = menu.addAction("Вставить")
        a_paste.setShortcut("Ctrl+V")

        a_del = menu.addAction("Удалить")

        menu.addSeparator()

        a_all = menu.addAction("Выделить всё")
        a_all.setShortcut("Ctrl+A")

        has_sel = self.hasSelectedText()
        a_cut.setEnabled(has_sel and not self.isReadOnly())
        a_copy.setEnabled(has_sel)
        a_paste.setEnabled(not self.isReadOnly())
        a_del.setEnabled(has_sel and not self.isReadOnly())
        a_undo.setEnabled(self.isUndoAvailable() and not self.isReadOnly())
        a_redo.setEnabled(self.isRedoAvailable() and not self.isReadOnly())

        chosen = menu.exec(event.globalPos())

        if chosen == a_undo:
            self.undo()
        elif chosen == a_redo:
            self.redo()
        elif chosen == a_cut:
            self.force_cut()
        elif chosen == a_copy:
            self.force_copy()
        elif chosen == a_paste:
            self.force_paste()
        elif chosen == a_del:
            self.del_()
        elif chosen == a_all:
            self.selectAll()


class ClipboardPlainTextEdit(QPlainTextEdit):
    def _clipboard_text(self) -> str:
        cb = QApplication.clipboard()
        try:
            md = cb.mimeData()
            if md and md.hasText():
                return md.text()
        except Exception:
            pass
        try:
            value = cb.text()
            if value:
                return value
        except Exception:
            pass

        for cmd in (
            ["wl-paste", "--no-newline"],
            ["wl-paste", "-n"],
            ["xclip", "-selection", "clipboard", "-o"],
            ["xsel", "-b", "-o"],
        ):
            try:
                out = subprocess.check_output(cmd, stderr=subprocess.DEVNULL, timeout=1)
                value = out.decode("utf-8", errors="replace")
                if value:
                    return value
            except Exception:
                pass
        return ""

    def force_paste(self, *args):
        if self.isReadOnly():
            return
        old = self.toPlainText()
        try:
            self.paste()
            if self.toPlainText() != old:
                return
        except Exception:
            pass
        value = self._clipboard_text()
        if value:
            self.insertPlainText(value)

    def keyPressEvent(self, event):
        if event.matches(QKeySequence.Paste):
            self.force_paste()
            return
        super().keyPressEvent(event)

    def contextMenuEvent(self, event):
        menu = self.createStandardContextMenu()
        menu.addSeparator()
        a_paste = menu.addAction('Вставить принудительно')
        a_paste.setShortcut('Ctrl+V')
        a_paste.setEnabled(not self.isReadOnly())
        chosen = menu.exec(event.globalPos())
        if chosen == a_paste:
            self.force_paste()


