def _exe_if_exists(version_dir: Path, name: str) -> Optional[str]:
    exe = version_dir / name
    if exe.is_file():
        return str(exe)
    return None


def _preferred_designer_exe(version_dir: Path) -> Optional[str]:
    # Для Конфигуратора и пакетных операций предпочтительнее 1cv8.
    for name in ['1cv8', '1cv8c', '1cv8s', '1cestart']:
        exe = _exe_if_exists(version_dir, name)
        if exe:
            return exe
    return None


def _preferred_client_exe(version_dir: Path, client_mode: str) -> Optional[str]:
    mode = (client_mode or 'thin').strip().lower()

    if mode in ('thick', 'толстый', '1cv8s'):
        order = ['1cv8s', '1cv8', '1cv8c', '1cestart']
    else:
        order = ['1cv8c', '1cv8', '1cv8s', '1cestart']

    for name in order:
        exe = _exe_if_exists(version_dir, name)
        if exe:
            return exe
    return None


def find_platforms() -> Dict[str, str]:
    """Найти установленные версии.

    Значение словаря — исполняемый файл для технических/пакетных операций,
    то есть предпочтительно 1cv8. Для интерактивного запуска кнопкой
    используется отдельная функция select_interactive_platform_exe().
    """
    found = {}

    for root in platform_search_roots():
        if not root.exists():
            continue

        for d in root.iterdir():
            if not d.is_dir():
                continue
            exe = _preferred_designer_exe(d)
            if exe:
                found[d.name] = exe

        exe = _preferred_designer_exe(root)
        if exe:
            found[root.name] = exe

    return dict(sorted(found.items(), key=lambda x: version_key(x[0]), reverse=True))


def is_auto_platform_version(version: str) -> bool:
    v = (version or '').strip().lower()
    return v in ('', 'любая', 'auto', 'авто')


def is_generic_platform_version(version: str) -> bool:
    # Оставлено для совместимости старых вызовов.
    return is_auto_platform_version(version)


def platform_versions_text() -> str:
    platforms = find_platforms()
    if not platforms:
        return '<платформы не найдены>'
    return ', '.join(f'{ver}={exe}' for ver, exe in platforms.items())


def platform_family_prefix(version: str) -> str:
    v = (version or '').strip()
    if v in ('8', '8.*'):
        return '8.'
    if v.endswith('.*'):
        return v[:-2] + '.'
    if v in ('8.3', '8.5'):
        return v + '.'
    parts = v.split('.')
    if len(parts) in (2, 3):
        return v + '.'
    return ''


def installed_platform_choices() -> List[str]:
    choices = ['8.*', '8.3', '8.5']
    for ver in find_platforms().keys():
        if ver not in choices:
            choices.append(ver)
    return choices


def find_platform_exe_for_version(version: str) -> Optional[str]:
    """Исполняемый файл для пакетных операций/конфигуратора.

    8.* -> самая свежая 8.*
    8.3 -> самая свежая 8.3.*
    8.5 -> самая свежая 8.5.*
    точная версия -> указанная версия
    """
    v = (version or '').strip()
    if is_auto_platform_version(v):
        return None

    platforms = find_platforms()
    if v in platforms:
        return platforms[v]

    prefix = platform_family_prefix(v)
    matches = []
    if prefix:
        matches = [(ver, exe) for ver, exe in platforms.items() if ver.startswith(prefix)]
    else:
        matches = [(ver, exe) for ver, exe in platforms.items() if ver.startswith(v + '.') or ver.startswith(v)]

    if matches:
        matches.sort(key=lambda x: version_key(x[0]), reverse=True)
        return matches[0][1]

    for root in platform_search_roots():
        exe = _preferred_designer_exe(root / v)
        if exe:
            return exe

    return None


def default_platform_exe_for_generic(configured: str = '') -> Optional[str]:
    """Платформа для пусто/auto.

    Если глобальная настройка не указана, берется самая свежая найденная 8.*.
    """
    if configured and Path(configured).exists() and os.access(configured, os.X_OK):
        return configured

    exe = find_platform_exe_for_version('8.*')
    if exe:
        return exe

    for p in [
        '/opt/1cv8/common/1cv8',
        '/opt/1cv8/common/1cestart',
        '/opt/1C/v8.3/common/1cv8',
        '/opt/1C/v8.3/common/1cestart',
        '/opt/1C/v8.5/common/1cv8',
        '/opt/1C/v8.5/common/1cestart',
    ]:
        if Path(p).exists() and os.access(p, os.X_OK):
            return p

    platforms = find_platforms()
    if platforms:
        return next(iter(platforms.values()))

    return None


def select_interactive_platform_exe(base: BaseItem, settings: Settings) -> Optional[str]:
    """Исполняемый файл для кнопки "Запустить".

    Правила:
    - 8.* — /opt/1cv8/common/1cestart;
    - 8.3 — самая свежая установленная 8.3.*;
    - 8.5 — самая свежая установленная 8.5.*;
    - конкретная версия — именно она;
    - режим клиента:
      thin -> 1cv8c;
      thick -> 1cv8s, fallback 1cv8.
    """
    version = (base.platform_version or '').strip()

    if version == '8.*':
        launcher = find_1cestart(settings.one_c_common_path)
        if launcher:
            return launcher

    if is_auto_platform_version(version):
        configured = settings.selected_platform
        if configured and Path(configured).exists():
            return configured
        version = '8.*'

    technical_exe = find_platform_exe_for_version(version)
    if not technical_exe:
        return None

    version_dir = Path(technical_exe).parent
    exe = _preferred_client_exe(version_dir, base.client_mode)
    return exe or technical_exe


def select_web_platform_exe(base: BaseItem, settings: Settings) -> Optional[str]:
    # Для web-базы используем те же правила, но без перебора нескольких стартов.
    return select_interactive_platform_exe(base, settings)




