def bundled_metadata_probe_path() -> str:
    path = Path(__file__).resolve().parent / 'tools' / 'metadata_probe' / 'DbInfo.epf'
    return str(path) if path.exists() else ''


def is_stale_metadata_probe_path(path_value: str) -> bool:
    # Старый/битый путь к встроенной обработке надо заменить на DbInfo.epf текущей сборки.
    if not path_value:
        return True

    p = Path(path_value)
    normalized = str(p)

    if not p.exists():
        return True

    current_root = str(Path(__file__).resolve().parent)

    if p.name.lower() == 'dbinfo.epf' and 'updater1c-linux-stage' in normalized and current_root not in normalized:
        return True

    stale_markers = [
        'updater1c-linux-stage4',
        'updater1c-linux-stage3',
        'stage4-dbinfo',
        'stage4-metadata',
    ]
    return any(marker in normalized for marker in stale_markers)


def safe_name(value: str) -> str:
    return re.sub(r'[^0-9A-Za-zА-Яа-я_.-]+', '_', (value or 'base').strip())


def now_stamp() -> str:
    return time.strftime('%Y-%m-%d_%H-%M-%S')


def dataclass_from_dict(cls, data: dict):
    known = {f.name for f in fields(cls)}
    return cls(**{k: v for k, v in data.items() if k in known})


