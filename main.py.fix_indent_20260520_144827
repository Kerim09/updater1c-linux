        self.recalc_totals.setChecked(True)
        self.rebuild = QCheckBox('Реструктуризация таблиц')
        self.rebuild.setChecked(True)

        self.time_limit = make_line()
        self.resume = QCheckBox('Продолжить прерванное ранее тестирование')
        self.execute = QCheckBox('Выполнить команду, а не только показать')
        self.execute.setChecked(False)

        form = QFormLayout()
        form.addRow('', self.repair)
        form.addRow('', self.check_extensions)
        form.addRow('', self.check_logical)
        form.addRow('', self.check_refs)
        form.addRow('Ссылки на несуществующие объекты:', self.bad_ref_action)
        form.addRow('Частично потерянные данные:', self.bad_data_action)
        form.addRow('', self.reindex)
        form.addRow('', self.compress)
        form.addRow('', self.recalc_totals)
        form.addRow('', self.rebuild)
        form.addRow('Прервать через, мин:', self.time_limit)
        form.addRow('', self.resume)
        form.addRow('', self.execute)

        ok = QPushButton('OK')
        cancel = QPushButton('Отмена')
        ok.clicked.connect(self.accept)
