    def selected_or_current_base_for_report(self):
        try:
            # 1. Если есть явно сохраненная база операции
            op_name = getattr(self, 'last_operation_base_name', '').strip()
            if op_name:
                for b in self.app_config.bases:
                    if b.name == op_name:
                        return b

            # 2. Если есть отмеченные базы
            idxs = self.checked_base_indices()
            if idxs:
                return self.app_config.bases[idxs[0]]

            # 3. Если есть текущая выбранная база
            if self.current_base_index is not None:
                return self.app_config.bases[self.current_base_index]

            # 4. Если справа уже отображена база
            ui_name = self.current_op_base.text().strip() if hasattr(self, 'current_op_base') else ''
            if ui_name and ui_name != '-':
                for b in self.app_config.bases:
                    if b.name == ui_name:
                        return b
        except Exception:
            pass
        return None

    def refresh_backup_combo(self):
        self.backup_combo.clear()
        base = self.selected_or_current_base_for_report()
        if not base:
            ui_name = self.current_op_base.text().strip() if hasattr(self, 'current_op_base') else ''
            if ui_name and ui_name != '-':
                self.backup_base_label.setText(f'База: {ui_name}')
            else:
                self.backup_base_label.setText('База: -')
            return

        self.backup_base_label.setText(f'База: {base.name}')
        bdir = Path(self.app_config.settings.backup_dir).expanduser() / safe_name(base.name)
        files = []
        if bdir.exists():
            files = sorted(
                list(bdir.glob('*.tar.gz')) + list(bdir.glob('*.dt')) + list(bdir.glob('*.backup')),
                key=lambda x: x.stat().st_mtime,
                reverse=True
            )

        for f in files:
            self.backup_combo.addItem(f'{f.name}', str(f))

    def emergency_abort_current_operation(self):
        base = self.selected_or_current_base_for_report()
        base_text = base.name if base else 'выбранной базы'

        ans = QMessageBox.warning(
            self,
            'Подтверждение аварийного завершения',
            f'Вы собираетесь принудительно завершить процесс 1С для базы: {base_text}.\n\n'
            f'Это может прервать обновление и оставить базу в промежуточном состоянии.\n\n'
            f'Продолжить?',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )
        if ans != QMessageBox.Yes:
            self.log('Аварийное завершение отменено пользователем.')
            return

        ans2 = QMessageBox.critical(
            self,
            'Последнее предупреждение',
            'Процесс 1С будет завершен принудительно.\n\n'
            'После этого может потребоваться восстановление базы из резервной копии.\n\n'
            'Точно прервать процесс сейчас?',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )
        if ans2 != QMessageBox.Yes:
            self.log('Аварийное завершение отменено на последнем подтверждении.')
            return

        try:
            import subprocess, shlex

            patterns = []
            if base:
                if base.connect:
                    patterns.append(str(base.connect))
                patterns.append(str(base.name))

            killed = False
            for pat in patterns:
                if not pat:
                    continue
                subprocess.run(['pkill', '-TERM', '-f', pat], check=False)
                killed = True

            # fallback: если выбранной базы нет, пробуем остановить активные 1cv8/xvfb
            if not killed:
                subprocess.run(['pkill', '-TERM', '-f', '1cv8'], check=False)
                subprocess.run(['pkill', '-TERM', '-f', 'xvfb-run'], check=False)

            self.report_status.setText('Статус: процесс прерван пользователем')
            self.report_badge.setText('ПРЕРВАНО')
            self.report_badge.setStyleSheet('color:#dc2626; border:1px solid #ef4444; border-radius:4px; padding:4px 10px; font-weight:bold;')
            self.log('АВАРИЙНО: отправлен сигнал завершения процессу 1С.')

            if hasattr(self, 'chk_offer_restore') and self.chk_offer_restore.isChecked():
                self.refresh_backup_combo()
                if self.backup_combo.count() > 0:
                    ans2 = QMessageBox.question(
                        self,
                        'Откат из резервной копии',
                        'Предложить восстановление из последней резервной копии?\n\n'
                        f'{self.backup_combo.currentText()}',
                        QMessageBox.Yes | QMessageBox.No,
                        QMessageBox.No
                    )
                    if ans2 == QMessageBox.Yes:
                        self.restore_selected_backup()
        except Exception as e:
            QMessageBox.warning(self, 'Ошибка', f'Не удалось аварийно завершить процесс:\n{e}')

    def restore_selected_backup(self):
        base = self.selected_or_current_base_for_report()
        if not base:
            QMessageBox.warning(self, 'Нет базы', 'Выберите базу для восстановления.')
            return

        if self.backup_combo.count() <= 0:
            QMessageBox.warning(self, 'Нет резервной копии', 'Для выбранной базы не найдены резервные копии.')
            return

        backup = Path(self.backup_combo.currentData())
        if not backup.exists():
            QMessageBox.warning(self, 'Файл не найден', f'Резервная копия не найдена:\n{backup}')
            return

        if base.kind != 'file':
            QMessageBox.warning(self, 'Пока только file-базы', 'Автоматический откат сейчас реализован только для file-баз 1С.')
            return

        db_path = Path(base.connect)
        onecd = db_path / '1Cv8.1CD'

        ans = QMessageBox.warning(
            self,
            'Подтверждение восстановления',
            f'Текущая база будет заменена из резервной копии:\n{backup}\n\n'
            f'Целевая база:\n{onecd}\n\nПродолжить?',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )
        if ans != QMessageBox.Yes:
            return

        try:
            import subprocess, tarfile, tempfile, shutil

            if self.chk_close_1c_before_restore.isChecked():
                subprocess.run(['pkill', '-TERM', '-f', str(db_path)], check=False)

            if backup.suffixes[-2:] == ['.tar', '.gz'] or str(backup).endswith('.tar.gz'):
                with tempfile.TemporaryDirectory() as td:
                    with tarfile.open(backup, 'r:gz') as tar:
                        tar.extractall(td)
                    found = list(Path(td).rglob('1Cv8.1CD'))
                    if not found:
                        raise RuntimeError('В архиве не найден файл 1Cv8.1CD')
                    onecd.parent.mkdir(parents=True, exist_ok=True)
                    shutil.copy2(found[0], onecd)
            else:
                raise RuntimeError('Для автоматического восстановления поддержан архив .tar.gz с 1Cv8.1CD')

            self.log(f'Восстановление выполнено из резервной копии: {backup}')
            QMessageBox.information(self, 'Готово', 'База восстановлена из резервной копии.')
        except Exception as e:
            QMessageBox.warning(self, 'Ошибка восстановления', str(e))

