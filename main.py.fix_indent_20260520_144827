    def refresh_platform_versions(self):
        current = self.platform_version.currentText().strip() if hasattr(self, 'platform_version') else ''
        self.platform_version.blockSignals(True)
        self.platform_version.clear()
        for ver in installed_platform_choices():
            self.platform_version.addItem(ver)
        if current and self.platform_version.findText(current) < 0:
            self.platform_version.addItem(current)
        if current:
            self.platform_version.setCurrentText(current)
        self.platform_version.blockSignals(False)

    def show_platform_menu(self):
        self.refresh_platform_versions()
        menu = QMenu(self)
        any8_action = menu.addAction('8.* — любая платформа 8')
        any8_action.triggered.connect(lambda: self.platform_version.setCurrentText('8.*'))
        family83_action = menu.addAction('8.3 — любая платформа 8.3')
        family83_action.triggered.connect(lambda: self.platform_version.setCurrentText('8.3'))
        family85_action = menu.addAction('8.5 — любая платформа 8.5')
        family85_action.triggered.connect(lambda: self.platform_version.setCurrentText('8.5'))

        menu.addSeparator()
        platforms = find_platforms()
        if not platforms:
            a = menu.addAction('Установленные платформы не найдены')
            a.setEnabled(False)
        else:
            for ver, exe in platforms.items():
                act = menu.addAction(f'{ver}  —  {exe}')
                act.triggered.connect(lambda checked=False, v=ver: self.platform_version.setCurrentText(v))

        menu.exec(self.platform_select_btn.mapToGlobal(self.platform_select_btn.rect().bottomLeft()))

    def update_platform_tooltip(self):
        version = self.platform_version.currentText().strip()
        dummy_base = BaseItem(name='__dummy__', platform_version=version)
        dummy_base.client_mode = self.client_mode.currentData() if hasattr(self, 'client_mode') else 'thin'

        if version == '8.*':
            exe = find_1cestart('')
            text = f'8.* — запуск через common/1cestart: {exe or "1cestart не найден"}'
        elif is_auto_platform_version(version):
            exe = default_platform_exe_for_generic('')
            text = f'auto — глобальная настройка или самая свежая найденная 8.*: {exe or "платформа не найдена"}'
        elif version in ('8.3', '8.5') or version.endswith('.*'):
            exe = find_platform_exe_for_version(version)
            text = f'{version} — самая свежая установленная платформа семейства: {exe or "платформа не найдена"}'
        else:
            exe = find_platform_exe_for_version(version)
            text = f'Конкретная версия {version}. Запуск будет через: {exe or "платформа не найдена"}'

        self.platform_version.setToolTip(text)
        self.platform_select_btn.setToolTip(text)


    def append_launch_parameter(self, template: str):
        current = self.launch_parameters.text().strip()
        if current:
            self.launch_parameters.setText(current + ' ' + template)
        else:
            self.launch_parameters.setText(template)
        self.launch_parameters.setFocus()

    def show_launch_params_menu(self):
        menu = QMenu(self)

        for template, description in self.LAUNCH_PARAMETER_TEMPLATES:
            act = menu.addAction(f'{template}    — {description}')
            act.triggered.connect(lambda checked=False, t=template: self.append_launch_parameter(t))

        menu.addSeparator()
        clear = menu.addAction('Очистить параметры')
        clear.triggered.connect(lambda: self.launch_parameters.setText(''))

        menu.exec(self.launch_param_btn.mapToGlobal(self.launch_param_btn.rect().bottomLeft()))

    def update_kind_visibility(self, kind: str):
        is_server = kind == 'server'
        self.db_box.setVisible(is_server)

        if kind == 'file':
            self.browse_btn.setEnabled(True)
            self.connect.setPlaceholderText('/mnt/Data/bases/BaseName')
        elif kind == 'server':
            self.browse_btn.setEnabled(False)
            self.connect.setPlaceholderText('server\\infobase')
        else:
            self.browse_btn.setEnabled(False)
            self.connect.setPlaceholderText('https://server/base')

        self.adjustSize()

    def browse_file_base(self):
        path = QFileDialog.getExistingDirectory(self, 'Выберите папку файловой базы')
        if path:
            self.connect.setText(path)
            self.kind.setCurrentText('file')

    
    def browse_template(self):
        dlg = TemplateSelectDialog(self)

        if dlg.exec() == QDialog.Accepted:
            if dlg.selected_template:
                self.template_path.setText(dlg.selected_template)

                kind_text = 'Демонстрационная база' if dlg.selected_template_kind == 'demo' else 'Чистая конфигурация'
                if hasattr(self, 'comment'):
                    cur = self.comment.toPlainText().strip()
                    extra = f'Шаблон 1С: {kind_text}; {dlg.selected_template_name}; версия {dlg.selected_template_version}'
                    self.comment.setPlainText((cur + '\n' + extra).strip() if cur else extra)

                if hasattr(self, 'add_mode'):
                    idx = self.add_mode.findData('template')
                    if idx >= 0:
                        self.add_mode.setCurrentIndex(idx)



    def get_base(self) -> BaseItem:
        kind = self.kind.currentText()

        if kind == 'server':
            db_type = self.db_type.currentText()
            db_host = self.db_host.text().strip()
            db_port = self.db_port.text().strip() or '5432'
            db_name = self.db_name.text().strip()
            db_user = self.db_user.text().strip()
            db_password = self.db_password.text()
        else:
            db_type = 'none'
            db_host = ''
            db_port = ''
            db_name = ''
            db_user = ''
            db_password = ''

        group_text = self.group.currentText().strip() if hasattr(self.group, 'currentText') else self.group.text().strip()
        mode = self.add_mode.currentData() if hasattr(self, 'add_mode') else 'existing'

        if mode == 'group':
            b = BaseItem(
                name=self.name.text().strip(),
                group='',
                kind='group',
                connect='',
                platform_version='',
            )
            return b

        b = BaseItem(
            name=self.name.text().strip(),
            group=group_text,
            kind=kind,
            connect=self.connect.text().strip(),
            user=self.user.text().strip(),
            password=self.password.text(),
            platform_version=self.platform_version.currentText().strip() or '8.*',
            client_mode=self.client_mode.currentData() or 'thin',
            launch_parameters=self.launch_parameters.text().strip(),
            comment=self.comment.toPlainText().strip(),
            config_name=self.config_name.text().strip(),
            config_synonym=self.config_synonym.text().strip(),
            config_version=self.config_version.text().strip(),
            update_program_name=self.update_program_name.text().strip(),
            db_type=db_type,
            db_host=db_host,
            db_port=db_port,
            db_name=db_name,
            db_user=db_user,
            db_password=db_password,
        )
        b.add_mode = self.add_mode.currentData() if hasattr(self, 'add_mode') else 'existing'
        b.template_path = self.template_path.text().strip() if hasattr(self, 'template_path') else ''
        normalize_base(b)
        return b



