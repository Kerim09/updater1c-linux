    def auto_update_selected(self):
        targets = self.require_targets()
        if targets is None:
            return

        dlg = AutoUpdateDialog(self)
        if dlg.exec() != QDialog.Accepted:
            return

        vals = dlg.get_values()

        if vals['make_backup'] and QMessageBox.question(
            self,
            'Подтверждение обновления',
            'Перед обновлением будет создана резервная копия. Продолжить?',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        ) != QMessageBox.Yes:
            return

        if not vals['make_backup'] and QMessageBox.question(
            self,
            'Без резервной копии',
            'Запустить автообновление без резервной копии? Это рискованно.',
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        ) != QMessageBox.Yes:
            return

        def work(worker):
            self.ensure_dirs()
            worker.log(f'Баз к автообновлению: {len(targets)}')
            worker.log('Режим: полностью пакетный. Ручной выбор релиза и ручное нажатие кнопок не используется.')
            worker.log(f'Таймаут одной операции: {vals.get("timeout_seconds", 7200)} сек.')

            for n, idx in enumerate(targets, 1):
                worker.check_cancel('Операция остановлена до начала следующей базы.')
                base = self.prepare_base(self.app_config.bases[idx])
                program = guess_update_program_name(base)

                worker.log('')
                worker.log(f'[{n}/{len(targets)}] Автообновление базы: {base.name}')
                worker.log(f'Код программы обновлений: {program or "<не заполнен>"}')
                worker.log(f'Текущая версия в карточке базы: {base.config_version or "<не заполнена>"}')

                backup_file = None

                try:
                    if base.kind == 'web':
                        worker.log('ПРОПУСК: web-базы через DESIGNER по URL не обновляются.')
                        continue

                    if not program:
                        worker.log('ПРОПУСК: не заполнен код программы обновлений 1С.')
                        continue

                    platform = self.resolve_platform_exe(base)
                    if not platform:
                        worker.log('ОШИБКА: платформа 1С не найдена.')
                        continue

                    # Перенесем уже скачанные старые длинные структуры в новый плоский layout.
                    cleanup_old_long_update_layout(worker, self.app_config.settings, program)

                    steps = find_downloaded_update_steps(self.app_config.settings, program, base.config_version)
                    if not steps:
                        worker.log(f'Не найдены скачанные релизы в {update_program_dir(self.app_config.settings, program)}. Сначала нажми «Скачать обновления».')
                        continue

                    # Фильтруем уже примененные релизы, если версия в карточке заполнена.
                    current_version = (base.config_version or '').strip()
                    if current_version:
                        filtered = []
                        for rel, cfu, folder in steps:
                            rel_ver = rel.replace('_', '.')
                            if version_key(rel_ver) > version_key(current_version):
                                filtered.append((rel, cfu, folder))
                            else:
                                worker.log(f'Пропуск уже примененного/старого релиза: {rel} <= {current_version}')
                        steps = filtered

                    if not steps:
                        worker.log('Нет релизов новее текущей версии базы.')
                        continue

                    worker.log('Последовательность пакетного обновления:')
                    for rel, cfu, folder in steps:
                        worker.log(f'  {rel}: {cfu}')

                    backup_file = self.make_pre_update_backup(worker, base, platform, vals)

                    last_release = current_version

                    for rel, cfu, folder in steps:
                        if worker.is_cancel_requested():
                            worker.log('Отмена запрошена. Следующий релиз не начинается.')
                            break

                        worker.log('')
                        worker.log(f'=== Релиз {rel} ===')

                        # Шаг 1. Обновление конфигурации конкретным файлом релиза.
                        log_update_cfg = Path(self.app_config.settings.reports_dir) / f'{safe_name(base.name)}_01_UpdateCfg_{safe_name(rel)}_{now_stamp()}.log'
                        extra_update = [
                            '/DisableStartupDialogs',
                            '/DisableStartupMessages',
                            '/UpdateCfg', str(cfu),
                            '/Out', str(log_update_cfg),
                            '-NoTruncate'
                        ]
                        worker.log('Шаг 1. Пакетное обновление конфигурации /UpdateCfg без ручного выбора релиза...')
                        run_1c_batch(
                            worker,
                            build_1c_args(base, 'DESIGNER', platform, extra_update),
                            timeout=vals.get('timeout_seconds', 7200),
                            hidden_xvfb=vals.get('hidden_xvfb', False),
                            allow_error=False
                        )
                        worker.log('Хвост лога /UpdateCfg:')
                        worker.log(tail_file(log_update_cfg))
                        worker.log(f'Лог /UpdateCfg: {log_update_cfg}')

                        # Шаг 2. Обновление конфигурации базы данных.
                        if vals.get('update_db_cfg'):
                            log_update_db = Path(self.app_config.settings.reports_dir) / f'{safe_name(base.name)}_02_UpdateDBCfg_{safe_name(rel)}_{now_stamp()}.log'
                            extra_db = [
                                '/DisableStartupDialogs',
                                '/DisableStartupMessages',
                                '/UpdateDBCfg'
                            ]
                            if vals.get('server_update') and base.kind == 'server':
                                extra_db.append('-Server')
                            if vals.get('dynamic_update'):
                                extra_db.append('-Dynamic+')
                            extra_db.extend(['/Out', str(log_update_db), '-NoTruncate'])

                            worker.log('Шаг 2. Пакетное обновление конфигурации базы данных /UpdateDBCfg...')
                            run_1c_batch(
                                worker,
                                build_1c_args(base, 'DESIGNER', platform, extra_db),
                                timeout=vals.get('timeout_seconds', 7200),
                                hidden_xvfb=vals.get('hidden_xvfb', False),
                                allow_error=False
                            )
                            worker.log('Хвост лога /UpdateDBCfg:')
                            worker.log(tail_file(log_update_db))
                            worker.log(f'Лог /UpdateDBCfg: {log_update_db}')
                        else:
                            worker.log('Шаг 2 пропущен: /UpdateDBCfg отключен в диалоге.')

                        # Шаг 3. Обработчики обновления.
                        if vals.get('run_handlers'):
                            self.run_update_handlers_for_base(worker, base, platform, rel, vals)
                        else:
                            worker.log('Шаг 3 пропущен: обработчики обновления отключены в диалоге.')

                        last_release = rel.replace('_', '.')
                        self.update_base_version_after_release(idx, base, last_release, worker)
                        worker.log(f'Релиз {rel} применен. Версия в карточке обновлена на {last_release}.')

                        if worker.is_cancel_requested():
                            worker.log('Отмена запрошена. Текущий релиз завершен полностью, следующие релизы выполняться не будут.')
                            break

                    worker.log(f'Автообновление базы {base.name} завершено. Последний примененный релиз: {last_release}')

                except Exception as e:
                    worker.log(f'ОШИБКА автообновления базы {base.name}: {e}')
                    if vals.get('restore_on_error'):
                        try:
                            worker.log('Пробую выполнить откат из резервной копии...')
                            self.restore_pre_update_backup(worker, base, platform if "platform" in locals() else '', backup_file)
                        except Exception as re:
                            worker.log(f'ОШИБКА отката: {re}')
                    if vals.get('stop_on_error'):
                        raise

        self.start_worker(f'Автообновление: {self.target_label(targets)}', work)


    def update_selected(self):
        targets = self.require_targets()
        if targets is None:
            return

        dlg = UpdateDialog(self, self.app_config.settings.updates_dir)
        if dlg.exec() != QDialog.Accepted:
            return

        vals = dlg.get_values()
        cfu = vals['cfu_path']
        if not cfu or not Path(cfu).exists():
            QMessageBox.warning(self, 'Файл не найден', 'Выберите существующий .cfu/.cf')
            return

        def work(worker):
            worker.log(f'Баз к обновлению: {len(targets)}')
            worker.log(f'Файл обновления: {cfu}')

            for n, idx in enumerate(targets, 1):
                worker.check_cancel('Операция остановлена до начала следующей базы.')
                base = self.prepare_base(self.app_config.bases[idx])
                worker.log('')
                worker.log(f'[{n}/{len(targets)}] Обновление базы: {base.name}')

                try:
                    if base.kind == 'web':
                        worker.log('ПРОПУСК: web-базы через DESIGNER по URL не обновляются.')
                        continue

                    platform = self.resolve_platform_exe(base)
                    if not platform:
                        worker.log(f'ОШИБКА для базы {base.name}: платформа 1С не найдена.')
                        continue

                    if vals['backup_mode'] == 0:
                        self.make_dt_backup(worker, base, platform)
                    elif vals['backup_mode'] == 1:
                        self.make_native_backup(worker, base)

                    log_file = Path(self.app_config.settings.reports_dir) / f'{safe_name(base.name)}_UpdateCfg_{now_stamp()}.log'
                    extra = ['/UpdateCfg', cfu] + (['/UpdateDBCfg'] if vals['update_db_cfg'] else []) + ['/Out', str(log_file)]
                    run_command(worker, build_1c_args(base, 'DESIGNER', platform, extra))
                    worker.log('Хвост лога обновления:')
                    worker.log(tail_file(log_file))
                    worker.log(f'Лог: {log_file}')

                except Exception as e:
                    worker.log(f'ОШИБКА для базы {base.name}: {e}')

        self.start_worker(f'Обновление из .cfu: {self.target_label(targets)}', work)



def main():
    app = QApplication(sys.argv)
    app.setApplicationName('Обновлятор 1c linux')
    app.setDesktopFileName('io.github.kerim1c.updater1clinux')
    icon_path = app_icon_path()
    if icon_path:
        app.setWindowIcon(QIcon(icon_path))
    win = MainWindow()
    if icon_path:
        win.setWindowIcon(QIcon(icon_path))
    win.show()
    sys.exit(app.exec())
if __name__ == '__main__': main()
