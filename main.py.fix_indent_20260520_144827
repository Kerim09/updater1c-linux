    def base_key(self, base: BaseItem) -> str:
        return f'{base.kind}|{base.connect}|{base.name}'

    def sync_checked_from_tree(self):
        if not hasattr(self, 'tree') or self.refreshing_tree:
            return
        checked = set()
        for i in range(self.tree.topLevelItemCount()):
            group = self.tree.topLevelItem(i)
            for j in range(group.childCount()):
                item = group.child(j)
                idx = item.data(0, Qt.UserRole)
                if isinstance(idx, int) and item.checkState(0) == Qt.Checked:
                    checked.add(self.base_key(self.app_config.bases[idx]))
        self.checked_base_keys = checked

    def on_tree_item_changed(self, item, column):
        if self.refreshing_tree or column != 0:
            return
        idx = item.data(0, Qt.UserRole)
        if not isinstance(idx, int):
            return
        key = self.base_key(self.app_config.bases[idx])
        if item.checkState(0) == Qt.Checked:
            self.checked_base_keys.add(key)
        else:
            self.checked_base_keys.discard(key)

    def check_all_bases(self):
        self.refreshing_tree = True
        self.checked_base_keys = {
            self.base_key(b)
            for b in self.app_config.bases
            if not is_group_placeholder_base(b)
        }
        for i in range(self.tree.topLevelItemCount()):
            group = self.tree.topLevelItem(i)
            for j in range(group.childCount()):
                group.child(j).setCheckState(0, Qt.Checked)
        self.refreshing_tree = False

    def uncheck_all_bases(self):
        self.refreshing_tree = True
        self.checked_base_keys.clear()
        for i in range(self.tree.topLevelItemCount()):
            group = self.tree.topLevelItem(i)
            for j in range(group.childCount()):
                group.child(j).setCheckState(0, Qt.Unchecked)
        self.refreshing_tree = False

    def refresh_tree(self):
        self.sync_checked_from_tree()

        removed_placeholders = remove_group_placeholder_bases(self.app_config.bases)
        if removed_placeholders:
            self.app_config.save()
            self.checked_base_keys = {
                self.base_key(b)
                for b in self.app_config.bases
                if not is_group_placeholder_base(b)
            }

        self.refreshing_tree = True
        self.tree.clear()
        groups = {}
        hidden_placeholders = 0
        for idx, base in enumerate(self.app_config.bases):
            normalize_base(base)
            if is_group_placeholder_base(base):
                hidden_placeholders += 1
                continue
            g = base.group or 'Без группы'
            if g not in groups:
                item = QTreeWidgetItem([g])
                item.setData(0, Qt.UserRole, None)
                self.tree.addTopLevelItem(item)
                groups[g] = item

            dbv = f'{base.db_host}:{base.db_port}/{base.db_name}' if base.kind == 'server' and base.db_name else ''
            title_conf = base.config_synonym or base.config_name

            row = QTreeWidgetItem([base.name, base.kind, title_conf, base.config_version, base.connect, base.platform_version, dbv])
            row.setFlags(row.flags() | Qt.ItemIsUserCheckable | Qt.ItemIsSelectable | Qt.ItemIsEnabled)
            row.setCheckState(0, Qt.Checked if self.base_key(base) in self.checked_base_keys else Qt.Unchecked)
            row.setData(0, Qt.UserRole, idx)
            groups[g].addChild(row)

        self.tree.expandAll()
        self.refreshing_tree = False
        self.load_selected_credentials()

    def selected_base_index(self):
        item = self.tree.currentItem()
        idx = item.data(0, Qt.UserRole) if item else None
        return idx if isinstance(idx, int) else None

    def selected_base(self):
        idx = self.selected_base_index()
        return self.app_config.bases[idx] if idx is not None else None

    def checked_base_indices(self):
        self.sync_checked_from_tree()
        result = []
        for idx, base in enumerate(self.app_config.bases):
            if is_group_placeholder_base(base):
                continue
            if self.base_key(base) in self.checked_base_keys:
                result.append(idx)
        return result

    def target_base_indices(self):
        checked = self.checked_base_indices()
        if checked:
            return checked
        idx = self.selected_base_index()
        return [idx] if idx is not None else []

    def require_targets(self):
        targets = self.target_base_indices()
        if not targets:
            QMessageBox.information(self, 'Нет баз', 'Отметьте одну или несколько баз галочками или выберите одну базу.')
            return None
        return targets

    def target_label(self, targets):
        if len(targets) == 1:
            return self.app_config.bases[targets[0]].name
        return f'{len(targets)} баз'

