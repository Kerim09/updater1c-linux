def version_key(version: str) -> Tuple[int, ...]:
    nums = [int(x) for x in re.findall(r'\d+', version or '')]
    return tuple(nums or [0])


def platform_search_roots() -> List[Path]:
    """Каталоги, где на Linux обычно лежат платформы 1С.

    У пользователя 8.3 и 8.5 лежат однотипно:
    /opt/1cv8/x86_64/8.3...
    /opt/1cv8/x86_64/8.5...
    Поэтому 8.5 ищем там же, а не только в /opt/1C/v8.5.
    """
    return [
        Path('/opt/1cv8/x86_64'),
        Path('/opt/1cv8/i386'),
        Path('/opt/1C/v8.3/x86_64'),
        Path('/opt/1C/v8.3/i386'),
        Path('/opt/1C/v8.5/x86_64'),
        Path('/opt/1C/v8.5/i386'),
    ]


