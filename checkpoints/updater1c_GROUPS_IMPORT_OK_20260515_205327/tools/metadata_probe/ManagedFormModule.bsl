// Модуль управляемой формы внешней обработки MetadataProbe.epf
// Минимальная задача: записать имя/синоним/версию конфигурации в файл и закрыть 1С.
//
// Приложение Python проверяет два варианта результата:
// 1) путь, переданный через /C: U1C_META_OUT=/path/to/result.json
// 2) fallback: /tmp/u1c_metadata_probe_result.txt
//
// Если не получится сразу разобрать /C в вашей конфигурации — для первого теста
// достаточно писать в fallback-файл /tmp/u1c_metadata_probe_result.txt.

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЗаписатьМетаданныеИЗакрыть();
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьМетаданныеИЗакрыть()
	ПутьФайла = ПолучитьПутьФайлаРезультата();
	Текст = ПолучитьТекстМетаданныхНаСервере();

	Док = Новый ТекстовыйДокумент;
	Док.УстановитьТекст(Текст);
	Док.Записать(ПутьФайла, КодировкаТекста.UTF8);

	// Важно: иначе процесс 1С останется висеть, а Python дождется таймаута.
	ЗавершитьРаботуСистемы(Ложь);
КонецПроцедуры

&НаКлиенте
Функция ПолучитьПутьФайлаРезультата()
	// Надежный fallback для Linux. Python-приложение его тоже проверяет.
	Возврат "/tmp/u1c_metadata_probe_result.txt";
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьТекстМетаданныхНаСервере()
	ИмяКонфигурации = Метаданные.Имя;
	СинонимКонфигурации = Строка(Метаданные.Синоним);
	ВерсияКонфигурации = Метаданные.Версия();

	Возврат "name=" + ИмяКонфигурации + Символы.ПС
		+ "synonym=" + СинонимКонфигурации + Символы.ПС
		+ "version=" + ВерсияКонфигурации + Символы.ПС;
КонецФункции
