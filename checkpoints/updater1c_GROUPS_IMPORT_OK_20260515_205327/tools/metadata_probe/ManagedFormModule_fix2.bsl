// Модуль управляемой формы внешней обработки DbInfo.epf.
// Вариант fix2:
// - не использует КаталогВременныхФайлов() на клиенте;
// - штатно читает путь результата из /C:
//     /CU1C_META_OUT=/tmp/u1c_meta_xxx.json
// - дополнительно умеет взять путь из переменной среды U1C_META_OUT;
// - если обработку открыли вручную, просто показывает данные и НЕ закрывает 1С.

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ПутьРезультата = ПолучитьПутьРезультата();

	Попытка

		ДанныеМетаданных = ПолучитьДанныеМетаданныхНаСервере();

		Если ПутьРезультата = "" Тогда
			// Ручной запуск обработки из интерфейса.
			Сообщить(
				"DbInfo: ручной запуск без /C." + Символы.ПС
				+ "Имя: " + ДанныеМетаданных.name + Символы.ПС
				+ "Синоним: " + ДанныеМетаданных.synonym + Символы.ПС
				+ "Версия: " + ДанныеМетаданных.version
			);
			Возврат;
		КонецЕсли;

		ЗаписатьРезультатJSONНаКлиенте(ПутьРезультата, Истина, ДанныеМетаданных, "");
		ЗавершитьРаботуСистемы(Ложь);

	Исключение

		Если ПутьРезультата <> "" Тогда
			ПустыеДанные = Новый Структура;
			ПустыеДанные.Вставить("name", "");
			ПустыеДанные.Вставить("synonym", "");
			ПустыеДанные.Вставить("version", "");
			ЗаписатьРезультатJSONНаКлиенте(ПутьРезультата, Ложь, ПустыеДанные, ОписаниеОшибки());
			ЗавершитьРаботуСистемы(Ложь);
		Иначе
			Сообщить("DbInfo: ошибка: " + ОписаниеОшибки());
		КонецЕсли;

	КонецПопытки;

КонецПроцедуры


&НаСервереБезКонтекста
Функция ПолучитьДанныеМетаданныхНаСервере()

	Результат = Новый Структура;

	Результат.Вставить("name", Метаданные.Имя);
	Результат.Вставить("synonym", Строка(Метаданные.Синоним));
	Результат.Вставить("version", Метаданные.Версия());

	Возврат Результат;

КонецФункции


&НаКлиенте
Функция ПолучитьПутьРезультата()

	ПутьРезультата = ПолучитьПутьРезультатаИзПараметраЗапуска();

	Если ПутьРезультата <> "" Тогда
		Возврат ПутьРезультата;
	КонецЕсли;

	// Fallback: приложение дополнительно передает env U1C_META_OUT.
	Попытка
		ПутьРезультата = ПолучитьПеременнуюСреды("U1C_META_OUT");
	Исключение
		ПутьРезультата = "";
	КонецПопытки;

	Возврат СокрЛП(ПутьРезультата);

КонецФункции


&НаКлиенте
Функция ПолучитьПутьРезультатаИзПараметраЗапуска()

	СтрокаПараметра = "";

	Попытка
		СтрокаПараметра = ПараметрЗапуска;
	Исключение
		СтрокаПараметра = "";
	КонецПопытки;

	СтрокаПараметра = СокрЛП(СтрокаПараметра);

	// Ожидаемый вид:
	// /CU1C_META_OUT=/tmp/u1c_meta_xxx.json
	// В ПараметрЗапуска попадает только:
	// U1C_META_OUT=/tmp/u1c_meta_xxx.json
	Префикс = "U1C_META_OUT=";

	Если Лев(СтрокаПараметра, 1) = """" И Прав(СтрокаПараметра, 1) = """" Тогда
		СтрокаПараметра = Сред(СтрокаПараметра, 2, СтрДлина(СтрокаПараметра) - 2);
	КонецЕсли;

	Если Лев(СтрокаПараметра, СтрДлина(Префикс)) = Префикс Тогда
		ПутьРезультата = Сред(СтрокаПараметра, СтрДлина(Префикс) + 1);
	Иначе
		ПутьРезультата = "";
	КонецЕсли;

	ПутьРезультата = СокрЛП(ПутьРезультата);

	Если СтрДлина(ПутьРезультата) >= 2 Тогда
		Если Лев(ПутьРезультата, 1) = """" И Прав(ПутьРезультата, 1) = """" Тогда
			ПутьРезультата = Сред(ПутьРезультата, 2, СтрДлина(ПутьРезультата) - 2);
		КонецЕсли;
	КонецЕсли;

	Возврат ПутьРезультата;

КонецФункции


&НаКлиенте
Процедура ЗаписатьРезультатJSONНаКлиенте(ПутьФайла, Успешно, ДанныеМетаданных, ТекстОшибки)

	ИмяКонфигурации = "";
	СинонимКонфигурации = "";
	ВерсияКонфигурации = "";

	Если ТипЗнч(ДанныеМетаданных) = Тип("Структура") Тогда
		ДанныеМетаданных.Свойство("name", ИмяКонфигурации);
		ДанныеМетаданных.Свойство("synonym", СинонимКонфигурации);
		ДанныеМетаданных.Свойство("version", ВерсияКонфигурации);
	КонецЕсли;

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();

	ЗаписьJSON.ЗаписатьНачалоОбъекта();

	ЗаписьJSON.ЗаписатьИмяСвойства("ok");
	ЗаписьJSON.ЗаписатьЗначение(Успешно);

	ЗаписьJSON.ЗаписатьИмяСвойства("name");
	ЗаписьJSON.ЗаписатьЗначение(ИмяКонфигурации);

	ЗаписьJSON.ЗаписатьИмяСвойства("synonym");
	ЗаписьJSON.ЗаписатьЗначение(СинонимКонфигурации);

	ЗаписьJSON.ЗаписатьИмяСвойства("version");
	ЗаписьJSON.ЗаписатьЗначение(ВерсияКонфигурации);

	ЗаписьJSON.ЗаписатьИмяСвойства("error");
	ЗаписьJSON.ЗаписатьЗначение(ТекстОшибки);

	ЗаписьJSON.ЗаписатьКонецОбъекта();

	ТекстJSON = ЗаписьJSON.Закрыть();

	ЗаписьТекста = Новый ЗаписьТекста(ПутьФайла, КодировкаТекста.UTF8);
	ЗаписьТекста.Записать(ТекстJSON);
	ЗаписьТекста.Закрыть();

КонецПроцедуры
